@{
    ViewData["Title"] = "Xuất thống kê";
    // xóa dòng Layout đi, tự dùng _Layout mặc định
}

<div class="container py-4">
    <h2 class="mb-4">
        <i class="bi bi-file-earmark-excel me-2 text-success"></i>Xuất thống kê Excel
    </h2>

    <div class="card shadow-sm" style="max-width: 500px;">
        <div class="card-header" style="background:#6b4f3b; color:#fff;">
            <i class="bi bi-calendar-range me-2"></i> Chọn khoảng thời gian
        </div>
        <div class="card-body">
            <form method="post" asp-action="ExportExcel">
                <div class="mb-3">
                    <label class="form-label fw-bold">Từ ngày</label>
                    <input type="date" name="fromDate" class="form-control"
                           value="@DateTime.Now.AddMonths(-1).ToString("yyyy-MM-dd")" required />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Đến ngày</label>
                    <input type="date" name="toDate" class="form-control"
                           value="@DateTime.Now.ToString("yyyy-MM-dd")" required />
                </div>

                <div class="mb-3 p-3 rounded" style="background:#f8f5f0;">
                    <p class="fw-bold mb-2">File Excel sẽ bao gồm:</p>
                    <ul class="mb-0" style="font-size:0.9rem;">
                        <li>📊 Sheet 1: Doanh thu theo ngày</li>
                        <li>🔥 Sheet 2: Sản phẩm bán chạy</li>
                        <li>👥 Sheet 3: Thống kê khách hàng</li>
                    </ul>
                </div>

                <button type="submit" class="btn w-100 text-white"
                        style="background:#6b4f3b;">
                    <i class="bi bi-download me-2"></i> Xuất file Excel
                </button>
            </form>
        </div>
    </div>
</div>