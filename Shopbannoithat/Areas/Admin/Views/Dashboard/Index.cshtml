@{
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

@* TRANG DASHBOARD THỐNG KÊ TỔNG DOANH THU,SẢN PHẨM BÁN CHẠY,TỈ LỆ SẢN PHẨM BÁN *@
@model Shopbannoithat.Models.DashboardViewModel

<link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800&display=swap" rel="stylesheet">

<div class="dash">
    <div class="dash-header">
        <h1 class="dash-title">Admin Dashboard</h1>
        <span class="dash-date" id="today"></span>
    </div>

    <!-- KPI Cards -->
    <div class="kpi-row">
        <div class="kpi-card kpi-revenue">
            <div class="kpi-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6" /></svg>
            </div>
            @* HIỂN THỊ TỔNG DOANH THU *@
            <div class="kpi-body">
                <span class="kpi-label">Tổng doanh thu</span>
                <span class="kpi-value">@Model.TotalRevenue.ToString("N0")<small>₫</small></span>
            </div>
            <div class="kpi-glow"></div>
        </div>
        @* HIỂN THỊ TỔNG ĐƠN HÀNG(SAU THI THANH TOÁN GIỎ HÀNG THÀNH CÔNG) *@
        <div class="kpi-card kpi-orders">
            <div class="kpi-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 7H4a2 2 0 00-2 2v10a2 2 0 002 2h16a2 2 0 002-2V9a2 2 0 00-2-2z" /><path d="M16 3H8l-2 4h12l-2-4z" /></svg>
            </div>
            <div class="kpi-body">
                <span class="kpi-label">Tổng đơn hàng</span>
                <span class="kpi-value">@Model.TotalOrders</span>
            </div>
            <div class="kpi-glow"></div>
        </div>
        @* HIỂN THỊ TỔNG SẢN PHẨM(KHI THÊM SẢN PHẨM NÓ SẼ TĂNG LÊN VÀ NGƯỢC LẠI) *@

        <div class="kpi-card kpi-products">
            <div class="kpi-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2" /><path d="M8 21h8M12 17v4" /></svg>
            </div>
            <div class="kpi-body">
                <span class="kpi-label">Tổng sản phẩm</span>
                <span class="kpi-value">@Model.TotalProducts</span>
            </div>
            <div class="kpi-glow"></div>
        </div>
    </div>

    @* HIỂN THỊ BIỂU ĐỒ SẢN PHẨM BÁN CHẠY *@
    <!-- Charts + Table -->
    <div class="dash-grid">
        <!-- Bar Chart -->
        <div class="dash-box chart-box">
            <div class="box-header">
                <h3>Sản phẩm bán chạy nhất</h3>
                <span class="box-sub">Top @Model.TopProducts.Count sản phẩm</span>
            </div>
            <div class="bar-chart" id="barChart"></div>
        </div>

    @* HIỂN THỊ BIỂU ĐỒ TỈ LỆ BÁN HÀNG *@
        <!-- Donut Chart -->
        <div class="dash-box donut-box">
            <div class="box-header">
                <h3>Tỷ lệ bán hàng</h3>
                <span class="box-sub">Theo số lượng</span>
            </div>
            <canvas id="donutChart" width="260" height="260"></canvas>
            <div class="donut-legend" id="donutLegend"></div>
        </div>
    </div>

    @* HIỂN THỊ DANH SÁCH CHI TIẾT SẢN PHẨM BÁN CHẠY *@
    <!-- Table -->
    <div class="dash-box table-box">
        <div class="box-header">
            <h3>Chi tiết sản phẩm bán chạy</h3>
        </div>
        <table class="dtable">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Tên sản phẩm</th>
                    <th>Đã bán</th>
                    <th>Tỷ lệ</th>
                </tr>
            </thead>
            <tbody>
                @{
                    var totalSold = Model.TopProducts.Sum(p => p.TotalSold);
                    int rank = 1;
                }
                @foreach (var p in Model.TopProducts)
                {
                    var pct = totalSold > 0 ? (p.TotalSold * 100.0 / totalSold) : 0;
                    <tr>
                        <td><span class="rank rank-@rank">@rank</span></td>
                        <td class="product-name">@p.ProductName</td>
                        <td><strong>@p.TotalSold</strong></td>
                        <td>
                            <div class="progress-wrap">
                                <div class="progress-bar" style="width:@pct.ToString("F0")%"></div>
                                <span>@pct.ToString("F1")%</span>
                            </div>
                        </td>
                    </tr>
                    rank++;
                }
            </tbody>
        </table>
    </div>
</div>

<script>
    // Date
    document.getElementById('today').textContent = new Date().toLocaleDateString('vi-VN', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });

    // Data from server
    // Dùng để chuẩn bị dữ liệu cho 2 biểu đồ bên dưới.
    // Lấy dữ liệu TopProducts từ C# server và chuyển thành JSON để JS dùng được
    const products = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TopProducts.Select(p => new { name = p.ProductName, sold = p.TotalSold })));
    // Định nghĩa 5 màu dùng cho biểu đồ, mỗi sản phẩm sẽ được tô 1 màu theo thứ tự:
    const colors = ['#6366f1','#f59e0b','#10b981','#ef4444','#3b82f6'];

    // ===== BAR CHART =====
    // Dùng để vẽ từng thanh trong biểu đồ cột ngang — mỗi sản phẩm 1 hàng, thanh dài hay ngắn tùy theo số lượng bán được.
    const barContainer = document.getElementById('barChart');
    const maxVal = Math.max(...products.map(p => p.sold));
    products.forEach((p, i) => {
        const pct = maxVal > 0 ? (p.sold / maxVal * 100) : 0;
        const shortName = p.name.length > 30 ? p.name.substring(0, 30) + '…' : p.name;
        barContainer.innerHTML += `
            <div class="bar-row">
                <div class="bar-label" title="${p.name}">${shortName}</div>
                <div class="bar-track">
                    <div class="bar-fill" style="width:${pct}%;background:${colors[i % colors.length]}" data-val="${p.sold}"></div>
                </div>
                <div class="bar-num">${p.sold}</div>
            </div>`;
    });
    // Animate bars
    // Dùng để tạo hiệu ứng fade in cho các thanh biểu đồ — sau 100ms khi trang load xong thì các thanh từ từ hiện ra thay vì hiện ngay lập tức.
    setTimeout(() => {
        document.querySelectorAll('.bar-fill').forEach(b => b.style.opacity = 1);
    }, 100);

    // ===== DONUT CHART =====
    // Dùng để vẽ biểu đồ tròn donut — mỗi sản phẩm 1 miếng, miếng to hay nhỏ tùy theo tỷ lệ số lượng bán so với tổng.
    const canvas = document.getElementById('donutChart');
    const ctx = canvas.getContext('2d');
    const total = products.reduce((s, p) => s + p.sold, 0);
    let startAngle = -Math.PI / 2;
    const cx = 130, cy = 130, r = 100, inner = 60;

    products.forEach((p, i) => {
        const slice = (p.sold / total) * 2 * Math.PI;
        ctx.beginPath();
        ctx.moveTo(cx, cy);
        ctx.arc(cx, cy, r, startAngle, startAngle + slice);
        ctx.closePath();
        ctx.fillStyle = colors[i % colors.length];
        ctx.fill();
        startAngle += slice;
    });

    // Inner circle (donut hole)
    // Dùng để vẽ hình tròn trắng ở giữa — che phần trung tâm của biểu đồ tròn lại để tạo thành hình donut (bánh vòng).
    ctx.beginPath();
    ctx.arc(cx, cy, inner, 0, 2 * Math.PI);
    ctx.fillStyle = '#fff';
    ctx.fill();

    // Center text
    // Dùng để viết chữ vào giữa donut — hiển thị tổng số lượng đã bán (to, đậm) và chữ "tổng bán" (nhỏ, xám) phía dưới.
    ctx.fillStyle = '#1e293b';
    ctx.font = 'bold 22px Be Vietnam Pro, sans-serif';
    ctx.textAlign = 'center';
    ctx.fillText(total, cx, cy + 4);
    ctx.font = '12px Be Vietnam Pro, sans-serif';
    ctx.fillStyle = '#94a3b8';
    ctx.fillText('tổng bán', cx, cy + 20);

    // Legend
    // Dùng để vẽ chú thích bên dưới biểu đồ tròn — mỗi sản phẩm 1 dòng gồm chấm màu + tên sản phẩm, để biết màu nào tương ứng với sản phẩm nào.
    const legend = document.getElementById('donutLegend');
    products.forEach((p, i) => {
        const shortName = p.name.length > 22 ? p.name.substring(0, 22) + '…' : p.name;
        legend.innerHTML += `<div class="legend-item"><span class="legend-dot" style="background:${colors[i]}"></span><span title="${p.name}">${shortName}</span></div>`;
    });
</script>

<style>
    * {
        box-sizing: border-box;
    }

    .dash {
        font-family: 'Be Vietnam Pro', sans-serif;
        padding: 28px;
        background: #f1f5f9;
        min-height: 100vh;
    }

    /* Header */
    .dash-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 28px;
    }

    .dash-title {
        font-size: 26px;
        font-weight: 800;
        color: #0f172a;
        margin: 0;
    }

    .dash-date {
        font-size: 13px;
        color: #64748b;
        font-weight: 500;
    }

    /* KPI */
    .kpi-row {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: 20px;
        margin-bottom: 24px;
    }

    .kpi-card {
        position: relative;
        display: flex;
        align-items: center;
        gap: 18px;
        padding: 24px;
        border-radius: 18px;
        color: white;
        overflow: hidden;
        box-shadow: 0 8px 24px rgba(0,0,0,0.12);
        transition: transform .25s, box-shadow .25s;
        cursor: default;
    }

        .kpi-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 16px 40px rgba(0,0,0,0.18);
        }

    .kpi-revenue {
        background: linear-gradient(135deg,#4f46e5,#7c3aed);
    }

    .kpi-orders {
        background: linear-gradient(135deg,#0891b2,#06b6d4);
    }

    .kpi-products {
        background: linear-gradient(135deg,#d97706,#f59e0b);
    }

    .kpi-icon {
        flex-shrink: 0;
        width: 52px;
        height: 52px;
        background: rgba(255,255,255,.2);
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .kpi-icon svg {
            width: 26px;
            height: 26px;
        }

    .kpi-label {
        display: block;
        font-size: 13px;
        opacity: .85;
        font-weight: 500;
        margin-bottom: 4px;
    }

    .kpi-value {
        display: block;
        font-size: 28px;
        font-weight: 800;
        line-height: 1;
    }

        .kpi-value small {
            font-size: 16px;
            font-weight: 600;
            margin-left: 3px;
            opacity: .9;
        }

    .kpi-glow {
        position: absolute;
        right: -20px;
        bottom: -20px;
        width: 100px;
        height: 100px;
        background: rgba(255,255,255,.08);
        border-radius: 50%;
    }

    /* Grid */
    .dash-grid {
        display: grid;
        grid-template-columns: 1fr 320px;
        gap: 20px;
        margin-bottom: 24px;
    }

    /* Box */
    .dash-box {
        background: white;
        border-radius: 18px;
        padding: 24px;
        box-shadow: 0 2px 12px rgba(0,0,0,.06);
    }

    .box-header {
        margin-bottom: 20px;
    }

        .box-header h3 {
            margin: 0 0 4px;
            font-size: 16px;
            font-weight: 700;
            color: #0f172a;
        }

    .box-sub {
        font-size: 12px;
        color: #94a3b8;
        font-weight: 500;
    }

    /* Bar chart */
    .bar-row {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 16px;
    }

    .bar-label {
        width: 200px;
        font-size: 13px;
        color: #475569;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        flex-shrink: 0;
    }

    .bar-track {
        flex: 1;
        height: 10px;
        background: #f1f5f9;
        border-radius: 99px;
        overflow: hidden;
    }

    .bar-fill {
        height: 100%;
        border-radius: 99px;
        opacity: 0;
        transition: width .8s cubic-bezier(.4,0,.2,1), opacity .3s;
    }

    .bar-num {
        width: 32px;
        text-align: right;
        font-size: 13px;
        font-weight: 700;
        color: #0f172a;
    }

    /* Donut */
    .donut-box {
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    #donutChart {
        margin: 8px 0;
    }

    .donut-legend {
        width: 100%;
        margin-top: 12px;
    }

    .legend-item {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 12px;
        color: #475569;
        margin-bottom: 6px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .legend-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    /* Table */
    .dtable {
        width: 100%;
        border-collapse: collapse;
    }

        .dtable thead tr {
            background: #f8fafc;
        }

        .dtable th {
            padding: 12px 16px;
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: .05em;
            color: #94a3b8;
            font-weight: 700;
            text-align: left;
        }

        .dtable td {
            padding: 14px 16px;
            font-size: 14px;
            color: #334155;
            border-bottom: 1px solid #f1f5f9;
        }

        .dtable tbody tr:hover {
            background: #fafafa;
        }

    .rank {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 26px;
        height: 26px;
        border-radius: 8px;
        font-size: 12px;
        font-weight: 800;
    }

    .rank-1 {
        background: #fef3c7;
        color: #d97706;
    }

    .rank-2 {
        background: #f1f5f9;
        color: #475569;
    }

    .rank-3 {
        background: #fef2f2;
        color: #ef4444;
    }

    .rank-4, .rank-5 {
        background: #f0fdf4;
        color: #16a34a;
    }

    .product-name {
        max-width: 400px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .progress-wrap {
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .progress-wrap > div {
            flex: 1;
            height: 8px;
            background: #f1f5f9;
            border-radius: 99px;
            overflow: hidden;
            max-width: 140px;
        }

    .progress-bar {
        height: 100%;
        background: linear-gradient(90deg,#6366f1,#8b5cf6);
        border-radius: 99px;
    }

    .progress-wrap span {
        font-size: 12px;
        color: #64748b;
        font-weight: 600;
        white-space: nowrap;
    }

    @@media (max-width: 900px) {
        .kpi-row {
            grid-template-columns: 1fr;
        }

        .dash-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

