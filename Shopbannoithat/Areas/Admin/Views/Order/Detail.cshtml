<style>
    /* Container chính cho toàn bộ trang */
    .invoice-container {
        max-width: 900px;
        margin: 30px auto;
        background: #07a6c5;
        padding: 40px;
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        border: 1px solid #edf2f7;

    }

    /* Tiêu đề chính */
    h2 {
        color: #2d3748;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 30px;
        border-bottom: 2px solid #f1f5f9;
        padding-bottom: 15px;
    }

    /* Khối thông tin khách hàng */
    .info-section {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
        margin-bottom: 40px;
        background: #f8fafc;
        padding: 20px;
        border-radius: 12px;
    }

    .info-item b {
        color: #64748b;
        font-size: 0.8rem;
        text-transform: uppercase;
        display: block;
        margin-bottom: 5px;
    }

    .info-item span {
        color: #1e293b;
        font-weight: 600;
        font-size: 1rem;
    }

    /* Tùy chỉnh bảng sản phẩm */
    .table {
        margin-top: 20px;
        border: none;
    }

        .table thead th {
            background-color: #f1f5f9;
            color: #475569;
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 0.05em;
            padding: 15px;
            border: none;
        }

        .table tbody td {
            padding: 15px;
            vertical-align: middle;
            border-bottom: 1px solid #f1f5f9;
            color: #334155;
        }

    /* Tổng tiền rực rỡ */
    .total-section {
        text-align: right;
        margin-top: 30px;
        padding: 20px;
        background: #fff5f5;
        border-radius: 10px;
    }

        .total-section h4 {
            margin: 0;
            font-weight: 800;
            color: #e53e3e;
        }

    /* Nút quay lại */
    .btn-secondary {
        margin-top: 20px;
        background-color: #39a76a;
        border: none;
        border-radius: 8px;
        padding: 10px 25px;
        font-weight: 600;
        transition: 0.3s;
    }

        .btn-secondary:hover {
            background-color: #1e293b;
            transform: translateY(-2px);
        }
</style>
<div class="invoice-container">
    <h2 style=" text-align:center;"><i class="fas fa-file-invoice"></i> Chi tiết đơn hàng</h2>

    <div class="info-section">
        <div class="info-item">
            <b>Mã đơn</b>
            <span>#ORD-@Model.Id</span>
        </div>
        <div class="info-item">
            <b>Khách hàng</b>
            <span>@Model.Name</span>
        </div>
        <div class="info-item">
            <b>Ngày đặt</b>
            <span>@Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</span>
        </div>
        <div class="info-item">
            <b>Địa chỉ</b>
            <span>@Model.Address1, @Model.Address2</span>
        </div>
        <div class="info-item">
            <b>Thành phố</b>
            <span>@Model.City</span>
        </div>
        <div class="info-item">
            <b>Trạng thái</b>
            <span style="color:#e05c2a; font-weight:700;">@Model.Status</span>
        </div>
        @if (!string.IsNullOrEmpty(Model.CouponCode))
        {
            <div class="info-item">
                <b>Mã giảm giá</b>
                <span>@Model.CouponCode (@Model.DiscountPercent%)</span>
            </div>
        }
    </div>

    <table class="table">
        <thead>
            <tr>
                <th>Sản phẩm</th>
                <th class="text-end">Giá</th>
                <th class="text-center">Số lượng</th>
                <th class="text-end">Thành tiền</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.OrderDetails)
            {
                <tr>
                    <td>
                        <div class="fw-bold">@item.Product?.Name</div>
                        @if (item.Variant != null)
                        {
                            <small style="color:white;">
                                @item.Variant.Size?.Name |
                                @item.Variant.Material?.Name |
                                <span style="display:inline-flex;align-items:center;gap:4px;">
                                    @if (item.Variant.Color != null)
                                    {
                                        <span style="width:12px;height:12px;border-radius:50%;background:@item.Variant.Color.HexCode;display:inline-block;border:1px solid #ddd;"></span>
                                        @item.Variant.Color.Name
                                    }
                                </span>
                            </small>
                        }
                        else if (!string.IsNullOrEmpty(item.VariantSize))
                        {
                            <small style="color:white;">
                                @item.VariantSize | @item.VariantMaterial | @item.VariantColor
                            </small>
                        }
                    </td>
                    <td class="text-end">@item.Price.ToString("N0") <small>đ</small></td>
                    <td class="text-center">@item.Quantity</td>
                    <td class="text-end fw-bold">@((item.Price * item.Quantity).ToString("N0")) <small>đ</small></td>
                </tr>
            }
        </tbody>
    </table>

    <div class="total-section shadow-sm">
        <h4>Tổng tiền thanh toán: @Model.TotalPrice.ToString("N0") VNĐ</h4>
    </div>

    <a asp-area="Admin" asp-controller="Order"  asp-action="Index" class="btn btn-secondary mt-4">
        <i class="fas fa-arrow-left"></i> Quay lại danh sách
    </a>
</div>