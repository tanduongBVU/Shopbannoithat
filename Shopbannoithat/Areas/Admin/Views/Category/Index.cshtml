@{
}


@model List<Shopbannoithat.Models.Category>

<h2>Quản lý loại sản phẩm</h2>

<a asp-action="Create" class="btn btn-success mb-3">Thêm loại</a>

<table class="table table-bordered">

    <thead>
        <tr>
            <th>ID</th>
            <th>Tên loại</th>
        </tr>
    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Name</td>
                

                <td>
                    <a asp-action="Edit"
                       asp-route-id="@item.Id"
                       class="btn btn-warning btn-sm">
                        Sửa
                    </a>

                    <a asp-action="Delete"
                       asp-route-id="@item.Id"
                       class="btn btn-danger btn-sm"
                       onclick="return confirm('Bạn có chắc muốn xóa?')">
                        Xóa
                    </a>
                </td>
            </tr>
        }

    </tbody>

</table>