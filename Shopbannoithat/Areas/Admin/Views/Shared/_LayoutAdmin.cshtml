@{
    ViewData["Title"] = "Xuất thống kê";
   
}

<!DOCTYPE html>
<html>
<head>
    <title>Admin Panel</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
</head>


<body>
    
    <div class="d-flex">

        <!-- SIDEBAR -->
        <div class="bg-dark text-white p-3" style="width:250px; height:100vh ; position: sticky; top: 0;
        overflow-y: auto">

            <h4>ADMIN</h4>
            <hr>

            <ul class="nav flex-column">

                <li class="nav-item">
                    <a class="nav-link text-white"
                           asp-area="Admin"
                           asp-controller="Dashboard"
                           asp-action="Index">
                        Dashboard
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link text-white"
                           asp-area="Admin"
                           asp-controller="Product"
                           asp-action="Index">
                        Quản lý sản phẩm
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link text-white"
                       asp-area="Admin"
                       asp-controller="Category"
                       asp-action="Index">
                        Quản lý danh mục
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link text-white"
                       asp-area="Admin"
                       asp-controller="Attribute"
                       asp-action="Index">
                        Quản lý biến thể sản phẩm
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link text-white"
                           asp-area="Admin"
                           asp-controller="Order"
                           asp-action="Index">
                        Quản lý đơn hàng
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link text-white"
                           asp-area="Admin"
                           asp-controller="User"
                           asp-action="Index">
                        Quản lý tài khoản
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link text-white"
                           asp-area="Admin"
                           asp-controller="Role"
                           asp-action="Index">
                        Quản lý quyền
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link text-white"
                           asp-area="Admin"
                           asp-controller="Coupon"
                           asp-action="Index">
                        Quản lý mã giảm giá
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link text-white"
                           asp-area="Admin"
                           asp-controller="Inventory"
                           asp-action="Index">
                        Quản lý kho
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link text-white"
                           asp-area="Admin"
                           asp-controller="Chat"
                           asp-action="Index">
                        <i class="bi bi-chat-dots"></i> Chat khách hàng
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link text-white"
                        asp-area="Admin" asp-controller="Export" asp-action="Index" >
                        <i class="bi bi-file-earmark-excel"></i> Xuất thống kê
                    </a>
                </li>
                
                <li class="nav-item">
                    <a class="nav-link text-white" href="/">
                        Về trang chủ
                    </a>
                </li>

            </ul>

        </div>

        <!-- CONTENT -->
        <div class="flex-grow-1 p-4">

            @RenderBody()
          
        </div>

    </div>

   

    @RenderSection("Scripts", required: false)

