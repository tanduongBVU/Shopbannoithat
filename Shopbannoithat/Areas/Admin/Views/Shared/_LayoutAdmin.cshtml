</html>

 <style>
    /* Custom Sidebar Styles */
    .admin-sidebar {
        background-color: #212529; /* Màu nền tối hiện đại */
        width: 260px;
        height: 100vh;
        box-shadow: 2px 0 10px rgba(0, 0, 0, 0.1); /* Đổ bóng nhẹ tách biệt với content */
        position: sticky; /* Làm cho menu dính lại */
        top: 0;
        overflow-y: auto; /* Tạo thanh cuộn riêng cho menu phòng trường hợp menu quá dài hoặc màn hình laptop nhỏ */
    }

        .admin-sidebar h4 {
            font-weight: 700;
            letter-spacing: 1px;
            color: #ffffff;
            padding: 1.5rem 1rem 0.5rem 1rem;
            margin-bottom: 0;
        }

        .admin-sidebar hr {
            border-color: rgba(255, 255, 255, 0.15);
            margin: 0 1.5rem 1rem 1.5rem;
        }

    .admin-menu {
        padding: 0 1rem;
    }

        .admin-menu .nav-item {
            margin-bottom: 4px;
        }

        .admin-menu .nav-link {
            color: #a2a3b7 !important; /* Màu chữ xám nhạt cho menu tĩnh */
            font-weight: 500;
            border-radius: 8px; /* Bo góc mềm mại */
            padding: 12px 15px;
         
            display: flex;
            align-items: center;
            gap: 12px; /* Khoảng cách giữa icon và text */
        }

            /* Hiệu ứng khi di chuột vào (Hover) */
            .admin-menu .nav-link:hover {
                color: #ffffff !important;
                background-color: #BEBDC175;
          
            }

            /* Trạng thái đang chọn (Active) - Lấy màu tím giống bảng dữ liệu của bạn */
            .admin-menu .nav-link.active {
                color: #ffffff !important;
                background-color: #6f42c1;
                transform: translateX(3px);
            }

            .admin-menu .nav-link i {
                font-size: 1.1rem; /* Chỉnh kích thước icon đồng đều */
            }
 </style>

