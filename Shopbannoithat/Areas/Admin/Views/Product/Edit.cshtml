@model Shopbannoithat.Models.Product

@{
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";

    // Tìm ParentId hiện tại của sản phẩm
    var allCategories = ViewBag.Categories as List<Shopbannoithat.Models.Category>;
    var currentCategory = allCategories?.FirstOrDefault(c => c.Id == Model.CategoryId);
    var currentParentId = currentCategory?.ParentId ?? currentCategory?.Id;
}

<h2>Sửa sản phẩm</h2>

<form asp-action="Edit" method="post">

    <input type="hidden" asp-for="Id" />

    <div class="mb-3">
        <label>Tên sản phẩm</label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label>Giá</label>
        <input asp-for="Price" class="form-control" />
        <span asp-validation-for="Price" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label>Hình ảnh</label>
        <input asp-for="Image" class="form-control" />
        <span asp-validation-for="Image" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label>Phòng</label>
        <select id="parentSelect" class="form-control" onchange="loadChildren(this.value)">
            <option value="">-- Chọn phòng --</option>
            @foreach (var p in ViewBag.Parents)
            {
                @if (p.Id == currentParentId)
                {
                    <option value="@p.Id" selected>@p.Name</option>
                }
                else
                {
                    <option value="@p.Id">@p.Name</option>
                }
            }
        </select>
    </div>

    <div class="mb-3">
        <label>Loại sản phẩm</label>
        <select name="CategoryId" id="childSelect" class="form-control">
            <option value="">-- Chọn loại --</option>
        </select>
        <span asp-validation-for="CategoryId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label>Số lượng</label>
        <input asp-for="Quantity" class="form-control" />
        <span asp-validation-for="Quantity" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label>Mô tả</label>
        <textarea asp-for="Description" class="form-control"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <button class="btn btn-success">Lưu</button>
    <a asp-action="Index" class="btn btn-secondary ms-2">Quay lại</a>

</form>

@section Scripts {
<script>
    var allChildren = @Html.Raw(ViewBag.ChildrenJson);
    var currentCategoryId = @Model.CategoryId;

    function loadChildren(parentId, selectedId) {
        var select = document.getElementById('childSelect');
        select.innerHTML = '<option value="">-- Chọn loại --</option>';
        if (!parentId) return;
        var filtered = allChildren.filter(c => c.parentId == parentId);
        filtered.forEach(function(c) {
            var selected = (c.id == selectedId) ? 'selected' : '';
            select.innerHTML += `<option value="${c.id}" ${selected}>${c.name}</option>`;
        });
    }

    // Load khi trang mở, tự chọn đúng loại hiện tại
    var initialParent = document.getElementById('parentSelect').value;
    if (initialParent) {
        loadChildren(initialParent, currentCategoryId);
    }

    document.getElementById('parentSelect').addEventListener('change', function() {
        loadChildren(this.value, null);
    });
</script>
}