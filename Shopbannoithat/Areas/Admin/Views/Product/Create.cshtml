@model Shopbannoithat.Models.Product


@* TRANG TẠO SẢN PHẨM MỚI *@
<h2>Thêm sản phẩm</h2>

<form asp-area="Admin" asp-controller="Product" asp-action="Create" method="post" enctype="multipart/form-data"> 
    
    
    @* NHẬP TÊN *@
    <div class="mb-3">
        <label class="form-label">Tên</label>
        <input asp-for="Name" class="form-control" value="@Model?.Name" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    @* NHẬP SỐ LƯỢNG *@
    <div class="mb-3">
        <label class="form-label">Số lượng</label>
        <input asp-for="Quantity" class="form-control" value="@Model?.Quantity" />
        <span asp-validation-for="Quantity" class="text-danger"></span>
    </div>

    @* CHỌN ẢNH *@
    <div class="mb-3">
        <label class="form-label">Ảnh sản phẩm</label>
        @if (!ViewData.ModelState.IsValid && Model?.Name != null)
        {
            <div class="alert alert-warning py-2" style="font-size:0.88rem;">
                ⚠️ Vui lòng chọn lại ảnh sản phẩm
            </div>
        }
        <div id="previewWrap" style="display:none; margin-bottom:8px;">
            <img id="imgPreview" style="height:120px; border-radius:10px; border:1px solid #ddd; object-fit:cover;" />
        </div>
        <input type="file" name="imageFile" class="form-control"
               accept="image/*" onchange="previewImage(this)" />
        <span asp-validation-for="Image" class="text-danger"></span>
    </div>

    @* NHẬP MÔ TẢ *@
    <div class="mb-3">
        <label class="form-label">Mô tả</label>
        <textarea asp-for="Description" class="form-control">@Model?.Description</textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    @* CHỌN PHÒNG *@
    <div class="mb-3">
        <label class="form-label">Phòng</label>
        <select id="parentSelect" class="form-control" onchange="loadChildren(this.value)">
            <option value="">-- Chọn phòng --</option>
            @foreach (var p in ViewBag.Parents)
            {
                <option value="@p.Id"
                        selected="@(Model?.Category?.ParentId == p.Id ? "selected" : null)">
                    @p.Name
                </option>
            }
        </select>
    </div>

    @* CHỌN LOẠI SẢN PHẨM *@
    <div class="mb-3">
        <label class="form-label">Loại sản phẩm</label>
        <select asp-for="CategoryId" id="childSelect" class="form-control">
            <option value="">-- Chọn phòng trước --</option>
        </select>
        <span asp-validation-for="CategoryId" class="text-danger"></span>
    </div>

    
   

    @* <div class="mb-3">
        <label class="form-label">Kích thước</label>
        <select asp-for="SizeId" class="form-control">
            <option value="">-- Chọn kích thước --</option>
            @foreach (var s in ViewBag.Sizes)
            {
                <option value="@s.Id">@s.Name</option>
            }
        </select>
    </div>

    <div class="mb-3">
        <label class="form-label">Vật liệu</label>
        <select asp-for="MaterialId" class="form-control">
            <option value="">-- Chọn vật liệu --</option>
            @foreach (var m in ViewBag.Materials)
            {
                <option value="@m.Id">@m.Name</option>
            }
        </select>
    </div>

    <div class="mb-3">
        <label class="form-label">Màu sắc</label>
        <select asp-for="ColorId" class="form-control">
            <option value="">-- Chọn màu sắc --</option>
            @foreach (var c in ViewBag.Colors)
            {
                <option value="@c.Id">@c.Name</option>
            }
        </select>
    </div> *@

    
    @* CHỌN BIẾN THỂ SẢN PHẨM (ĐÃ TẠO TỪ TRƯỚC) *@
    <div class="mb-3">
        <label class="form-label fw-bold">Biến thể sản phẩm (giá theo tổ hợp)</label>
        <div id="variantList"></div>
        <button type="button" onclick="addVariant()"
                style="background:#4facfe;color:#fff;border:none;padding:8px 16px;border-radius:8px;cursor:pointer;margin-top:8px;">
            + Thêm biến thể
        </button>
    </div>
  
    @* NÚT LƯU *@
    <button type="submit" class="btn btn-success">Lưu</button>
    @* NÚT QUAY LẠI *@
    <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="btn btn-secondary">Quay lại</a>

</form>

@section Scripts {
@{
    await Html.RenderPartialAsync("_ValidationScriptsPartial");
}
<script>
    // ===== DỮ LIỆU TỪ SERVER =====
    // Danh sách danh mục con dạng JSON để JS lọc theo phòng
    var allChildren = @Html.Raw(ViewBag.ChildrenJson);

    // CategoryId và ParentId đã chọn trước đó (dùng để khôi phục khi bị lỗi)
    var savedCategoryId = @(Model?.CategoryId.HasValue == true ? Model.CategoryId.Value.ToString() : "null");
    var savedParentId   = @Html.Raw(Model?.Category?.ParentId?.ToString() ?? "null");

    // Danh sách biến thể đã nhập trước đó (dùng để khôi phục khi bị lỗi)
    var savedVariants = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        Model?.Variants?.Select(v => new {
            sizeId     = v.SizeId,
            materialId = v.MaterialId,
            colorId    = v.ColorId,
            price      = v.Price,
            stock      = v.Stock
        }) ?? Enumerable.Empty<object>(),
        new System.Text.Json.JsonSerializerOptions {
            PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase
        }
    ));

    // ===== LOAD DANH MỤC CON THEO PHÒNG =====
    // Khi user chọn phòng, lọc danh mục con tương ứng và đổ vào select
    function loadChildren(parentId, selectedId) {
        var select = document.getElementById('childSelect');
        select.innerHTML = '<option value="">-- Chọn loại --</option>';
        if (!parentId) return;

        // Lọc danh mục con theo parentId
        var filtered = allChildren.filter(c => c.parentId == parentId);
        filtered.forEach(function(c) {
            // Nếu là danh mục đã chọn trước đó thì mark selected
            var sel = (selectedId && c.id == selectedId) ? 'selected' : '';
            select.innerHTML += `<option value="${c.id}" ${sel}>${c.name}</option>`;
        });
    }

    // ===== KHÔI PHỤC DỮ LIỆU KHI TRANG LOAD LẠI SAU LỖI =====
    window.addEventListener('load', function() {
        // Khôi phục phòng và loại sản phẩm đã chọn
        if (savedParentId) {
            document.getElementById('parentSelect').value = savedParentId;
            loadChildren(savedParentId, savedCategoryId);
        }

        // Khôi phục các biến thể đã nhập
        if (savedVariants && savedVariants.length > 0) {
            savedVariants.forEach(function(v) {
                addVariant(v); // gọi hàm addVariant với dữ liệu cũ
            });
        }
    });

    // ===== PREVIEW ẢNH TRƯỚC KHI SUBMIT =====
    // Khi user chọn file ảnh, hiển thị preview ngay lập tức
    function previewImage(input) {
        if (input.files && input.files[0]) {
            var reader = new FileReader();
            reader.onload = function(e) {
                document.getElementById('imgPreview').src = e.target.result;
                document.getElementById('previewWrap').style.display = 'block';
            };
            reader.readAsDataURL(input.files[0]);
        }
    }

    // ===== DỮ LIỆU SIZE / MATERIAL / COLOR TỪ SERVER =====
    var variantIndex = 0;
    const sizes     = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.Sizes));
    const materials = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.Materials));
    const colors    = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.Colors));

    // ===== THÊM DÒNG BIẾN THỂ MỚI =====
    // saved: object chứa dữ liệu cũ (nếu có) để khôi phục sau khi lỗi
    function addVariant(saved) {
        // Tạo option cho từng select, nếu có saved thì mark selected
        let sizeOpts     = sizes.map(s =>
            `<option value="${s.Id}" ${saved?.sizeId == s.Id ? 'selected' : ''}>${s.Name}</option>`
        ).join('');

        let materialOpts = materials.map(m =>
            `<option value="${m.Id}" ${saved?.materialId == m.Id ? 'selected' : ''}>${m.Name}</option>`
        ).join('');

        let colorOpts    = colors.map(c =>
            `<option value="${c.Id}" data-hex="${c.HexCode}" ${saved?.colorId == c.Id ? 'selected' : ''}>${c.Name}</option>`
        ).join('');

        const i = variantIndex++;

        // Chèn HTML dòng biến thể vào danh sách
        document.getElementById('variantList').insertAdjacentHTML('beforeend', `
            <div class="variant-row" style="display:grid;grid-template-columns:1fr 1fr 1fr 120px 100px 40px;gap:8px;margin-bottom:8px;align-items:center;">
                <select name="Variants[${i}].SizeId" class="form-control form-control-sm">
                    <option value="">-- Kích thước --</option>${sizeOpts}
                </select>
                <select name="Variants[${i}].MaterialId" class="form-control form-control-sm">
                    <option value="">-- Vật liệu --</option>${materialOpts}
                </select>
                <select name="Variants[${i}].ColorId" class="form-control form-control-sm color-select">
                    <option value="">-- Màu sắc --</option>${colorOpts}
                </select>
                <input name="Variants[${i}].Price" type="number" class="form-control form-control-sm"
                       placeholder="Giá" value="${saved?.price ?? ''}" />
                <input name="Variants[${i}].Stock" type="number" class="form-control form-control-sm"
                       placeholder="Tồn kho" value="${saved?.stock ?? 0}" />
                <button type="button" onclick="this.closest('.variant-row').remove()"
                        style="background:#e74c3c;color:#fff;border:none;border-radius:6px;padding:6px 10px;cursor:pointer;">✕</button>
            </div>`);

        // Xử lý đổi màu nền select Color theo mã HEX
        setTimeout(() => {
            const sel = document.querySelector(`select[name="Variants[${i}].ColorId"]`);

            // Nếu có saved colorId thì đổi màu nền ngay khi khôi phục
            if (saved?.colorId) {
                const opt = sel.querySelector(`option[value="${saved.colorId}"]`);
                const hex = opt?.getAttribute('data-hex');
                if (hex) {
                    sel.style.background = hex;
                    sel.style.color = '#fff';
                }
            }

            // Khi user thay đổi màu thì cập nhật màu nền select
            sel.addEventListener('change', function() {
                const selected = this.options[this.selectedIndex];
                const hex = selected.getAttribute('data-hex');
                this.style.background = hex || '';
                this.style.color = hex ? '#fff' : '#333';
            });
        }, 0);
    }

    // ===== VALIDATE TRƯỚC KHI SUBMIT =====
    let isSubmitting = false;

    document.querySelector('form').addEventListener('submit', function(e) {
        // Chặn submit 2 lần
        if (isSubmitting) { e.preventDefault(); return; }

        // Kiểm tra phải có ít nhất 1 biến thể
        const variantRows = document.querySelectorAll('.variant-row');
        if (variantRows.length === 0) {
            alert("❌ Vui lòng thêm ít nhất một biến thể sản phẩm!");
            e.preventDefault();
            return;
        }

        // Kiểm tra tổng tồn kho biến thể không vượt số lượng sản phẩm
        const productQty = parseInt(document.querySelector('[name="Quantity"]').value) || 0;
        let totalVariantStock = 0;
        document.querySelectorAll('input[name*=".Stock"]').forEach(input => {
            totalVariantStock += parseInt(input.value) || 0;
        });

        if (totalVariantStock > productQty) {
            alert("❌ Tổng tồn kho biến thể không được lớn hơn sản phẩm gốc!");
            e.preventDefault();
            isSubmitting = false; // reset để có thể submit lại
            return;
        }

        // Hợp lệ → cho phép submit
        isSubmitting = true;
    });
</script>
}



<style>
    /* Background toàn trang */
    body {
        background: linear-gradient(135deg, #eef2f7, #f8f9fa);
        font-family: 'Segoe UI', sans-serif;
    }

    /* Form tổng */
    form {
        max-width: 720px;
        margin: 50px auto;
        padding: 45px;
        background: rgba(255, 255, 255, 0.95);
        border-radius: 18px;
        box-shadow: 0 15px 40px rgba(0, 0, 0, 0.08);
        backdrop-filter: blur(10px);
        animation: fadeIn 0.6s ease;
    }

    /* Title */
    h2 {
        text-align: center;
        font-weight: 800;
        color: #2c3e50;
        margin-bottom: 35px;
        letter-spacing: 1px;
        position: relative;
    }

        h2::after {
            content: "";
            width: 60px;
            height: 4px;
            background: linear-gradient(90deg, #28a745, #20c997);
            display: block;
            margin: 10px auto;
            border-radius: 3px;
        }

    /* Label */
    .form-label {
        font-weight: 600;
        margin-bottom: 6px;
        color: #444;
    }

    /* Input */
    .form-control {
        border-radius: 10px;
        padding: 12px 15px;
        border: 1px solid #e0e6ed;
        background: #f9fbfd;
        transition: all 0.25s ease;
    }

        /* Focus đẹp hơn */
        .form-control:focus {
            border-color: #28a745;
            background: #fff;
            box-shadow: 0 0 0 3px rgba(40, 167, 69, 0.15);
            transform: scale(1.01);
        }

    /* Textarea */
    textarea.form-control {
        min-height: 130px;
    }

    /* Select custom */
    select.form-control {
        cursor: pointer;
        appearance: none;
        background-color: #f9fbfd;
        background-image: url("data:image/svg+xml,%3csvg fill='none' stroke='%236c757d' stroke-width='2' viewBox='0 0 24 24'%3e%3cpath d='M6 9l6 6 6-6'/%3e%3c/svg%3e");
        background-repeat: no-repeat;
        background-position: right 15px center;
        background-size: 14px;
    }

    /* File input */
    input[type="file"] {
        padding: 10px;
        background: #fff;
    }

    /* Error */
    .text-danger {
        font-size: 0.85rem;
        margin-top: 4px;
    }

    /* Button */
    .btn {
        padding: 12px 28px;
        border-radius: 10px;
        font-weight: 600;
        transition: all 0.25s ease;
    }

    /* Nút Lưu */
    .btn-success {
        background: linear-gradient(135deg, #28a745, #20c997);
        border: none;
        color: #fff;
        box-shadow: 0 6px 15px rgba(40, 167, 69, 0.25);
    }

        .btn-success:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(40, 167, 69, 0.35);
        }

    /* Nút Quay lại */
    .btn-secondary {
        background: #e9ecef;
        color: #333;
        margin-left: 10px;
    }

        .btn-secondary:hover {
            background: #dee2e6;
        }

    /* Animation */
    @@keyframes fadeIn {
        from

    {
        opacity: 0;
        transform: translateY(25px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }

    }
</style>