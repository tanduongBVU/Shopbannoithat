@{
}


@model List<Shopbannoithat.Models.Product>

<h2>Quản lý sản phẩm</h2>

<a asp-action="Create" class="btn btn-success mb-3">Thêm sản phẩm</a>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Hình</th>
            <th>Tên</th>
            <th>Giá</th>
            <th>Loại</th>
            <th>Mô tả</th>
            <th>Số lượng</th>
            
            <th>Chức năng</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    <img src="~/images/@item.Image" width="80" />
                </td>

                <td>@item.Name</td>

                <td>@item.Price?.ToString("N0")</td>

                <td>@item.Category?.Name</td>
                <td>@item.Description</td>
                <td>@item.Quantity</td>

                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning">Sửa</a>

                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger">Xóa</a>
                </td>
            </tr>
        }
    </tbody>
</table>