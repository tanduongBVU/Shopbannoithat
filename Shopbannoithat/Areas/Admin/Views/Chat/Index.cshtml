@model List<string>
@{
    ViewData["Title"] = "Quản lý chat";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="d-flex" style="height: 75vh;">

    <!-- Danh sách khách -->
    <div class="border-end pe-3 me-3" style="width: 260px; overflow-y: auto;">
        <h6 class="fw-bold mb-3"><i class="bi bi-people"></i> Khách hàng</h6>
        @if (!Model.Any())
        {
            <p class="text-muted small">Chưa có tin nhắn nào</p>
        }
        @foreach (var customer in Model)
        {
            <div class="customer-item p-2 rounded mb-1"
                 style="cursor:pointer; background:#f8f9fa;"
                 onclick="loadChat('@customer')">
                <i class="bi bi-person-circle me-1"></i>
                <small>@customer</small>
            </div>
        }
    </div>

    <!-- Khung chat -->
    <div class="flex-fill d-flex flex-column">
        <div id="chat-header" class="fw-bold mb-2 text-muted">
            ← Chọn khách để xem tin nhắn
        </div>

        <div id="chat-messages"
             class="flex-fill border rounded p-3 mb-2"
             style="overflow-y:auto; background:#fafafa;">
        </div>

        <div class="input-group" id="reply-box" style="display:none !important;">
            <input type="text" id="reply-input" class="form-control"
                   placeholder="Nhập tin nhắn trả lời..." />
            <button class="btn btn-primary" onclick="sendReply()">
                <i class="bi bi-send"></i> Gửi
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script>
        let currentCustomer = null;
        const myEmail = "@Context.Session.GetString("UserEmail")";
        const myRole = "@Context.Session.GetString("UserRole")";

        const connection = new signalR.HubConnectionBuilder()
        .withUrl("/chatHub")
        .withAutomaticReconnect()
        .build();

        connection.on("ReceiveMessage", function (senderEmail, senderRole, message, customerEmail, time) {
        // Nếu đang xem đúng cuộc chat này thì hiện lên
        if (customerEmail === currentCustomer) {
        appendMessage(senderEmail, senderRole, message, time);
        }
        });

        connection.start().catch(err => console.error(err));

        function loadChat(customerEmail) {
        currentCustomer = customerEmail;
        document.getElementById("chat-header").innerHTML =
        `<i class="bi bi-chat-dots text-primary"></i> Chat với: <strong>${customerEmail}</strong>`;
        document.getElementById("reply-box").style.display = "flex !important";
        document.getElementById("reply-box").removeAttribute("style");

        const box = document.getElementById("chat-messages");
        box.innerHTML = '<div class="text-muted small">Đang tải...</div>';

        fetch(`/Admin/Chat/GetHistory?customerEmail=${encodeURIComponent(customerEmail)}`)
        .then(r => r.json())
        .then(msgs => {
        box.innerHTML = "";
        msgs.forEach(m => appendMessage(m.senderEmail, m.senderRole, m.message, m.sentAt));
        box.scrollTop = box.scrollHeight;
        });

        // Highlight khách đang chọn
        document.querySelectorAll(".customer-item").forEach(el => el.classList.remove("bg-primary", "text-white"));
        event.currentTarget.classList.add("bg-primary", "text-white");
        }

        function appendMessage(senderEmail, senderRole, message, time) {
        const box = document.getElementById("chat-messages");
        const isMe = (senderRole === "Admin" || senderRole === "Staff");
        const div = document.createElement("div");
        div.className = `d-flex mb-2 ${isMe ? "justify-content-end" : "justify-content-start"}`;
        div.innerHTML = `
        <div style="max-width:70%">
        <div class="small text-muted mb-1">${isMe ? "Bạn" : senderEmail} · ${time}</div>
        <div class="rounded px-3 py-2" style="background:${isMe ? "#0d6efd" : "#e9ecef"}; color:${isMe ? "#fff" : "#000"}">
        ${message}
        </div>
        </div>`;
        box.appendChild(div);
        box.scrollTop = box.scrollHeight;
        }

        function sendReply() {
        const input = document.getElementById("reply-input");
        const msg = input.value.trim();
        if (!msg || !currentCustomer) return;
        connection.invoke("ReplyToCustomer", currentCustomer, msg)
        .catch(err => console.error(err));
        input.value = "";
        }

        document.getElementById("reply-input").addEventListener("keydown", function(e) {
        if (e.key === "Enter") sendReply();
        });
    </script>
}
<style>
    /* ===== KHUNG TỔNG ===== */
    .d-flex[style*="75vh"] {
        background: #f1f5f9;
        border-radius: 16px;
        padding: 10px;
    }

    /* ===== DANH SÁCH KHÁCH ===== */
    .customer-item {
        transition: all 0.25s ease;
        background: #ffffff !important;
        border: 1px solid #eee;
    }

        /* hover */
        .customer-item:hover {
            background: linear-gradient(90deg, #0984e3, #6c5ce7) !important;
            color: #fff;
            transform: translateX(5px);
        }

        /* active (nếu bạn add class active bằng JS sau này) */
        .customer-item.active {
            background: linear-gradient(90deg, #6c5ce7, #0984e3) !important;
            color: #fff;
        }

    /* ===== HEADER CHAT ===== */
    #chat-header {
        background: #fff;
        padding: 10px 15px;
        border-radius: 10px;
        border: 1px solid #eee;
        color: #2d3436 !important;
    }

    /* ===== KHUNG TIN NHẮN ===== */
    #chat-messages {
        background: #eaf1ff !important;
        border: none !important;
        border-radius: 12px;
    }

        /* ===== SCROLL BAR ===== */
        #chat-messages::-webkit-scrollbar {
            width: 6px;
        }

        #chat-messages::-webkit-scrollbar-thumb {
            background: #bbb;
            border-radius: 10px;
        }

    /* ===== BONG BÓNG CHAT ===== */
    /* tin nhắn khách */
    .message-customer {
        background: #ffffff;
        padding: 8px 12px;
        border-radius: 12px;
        margin-bottom: 8px;
        max-width: 70%;
        box-shadow: 0 3px 8px rgba(0,0,0,0.05);
    }

    /* tin nhắn admin */
    .message-admin {
        background: linear-gradient(90deg, #0984e3, #6c5ce7);
        color: #fff;
        padding: 8px 12px;
        border-radius: 12px;
        margin-bottom: 8px;
        margin-left: auto;
        max-width: 70%;
        box-shadow: 0 3px 10px rgba(0,0,0,0.1);
    }

    /* ===== INPUT ===== */
    #reply-input {
        border-radius: 10px 0 0 10px;
        border: 1px solid #ccc;
    }

        /* focus */
        #reply-input:focus {
            border-color: #6c5ce7;
            box-shadow: 0 0 0 2px rgba(108,92,231,0.2);
        }

    /* ===== BUTTON GỬI ===== */
    #reply-box .btn-primary {
        border-radius: 0 10px 10px 0;
        background: linear-gradient(90deg, #0984e3, #6c5ce7);
        border: none;
        transition: 0.3s;
    }

        /* hover */
        #reply-box .btn-primary:hover {
            transform: scale(1.05);
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        }

    /* ===== KHUNG DANH SÁCH ===== */
    .border-end {
        background: #ffffff;
        border-radius: 12px;
        padding: 10px;
    }

    /* title */
    h6 {
        color: #2d3436;
    }
</style>