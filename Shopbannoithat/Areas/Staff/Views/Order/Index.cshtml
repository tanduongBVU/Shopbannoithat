@{
    Layout = "~/Areas/Staff/Views/Shared/_LayoutStaff.cshtml";
}



@model List<Shopbannoithat.Models.Order>

<h2>Quản lý đơn hàng</h2>

<table class="table table-bordered">

    <thead>
        <tr>
            <th>Mã đơn</th>
            <th>Khách hàng</th>
            <th>Ngày đặt</th>
            <th>Tổng tiền</th>
            <th>Trạng thái</th>
            <th></th>
        </tr>
    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>

                <td>#ORD-@item.Id</td>

                <td>@item.Name</td>

                <td>@item.OrderDate</td>

                <td class="text-danger">
                    @item.TotalPrice.ToString("N0") VNĐ
                </td>

                <td>@item.Status</td>

                <td>
                <td>

                    <a asp-action="Detail"
                       asp-route-id="@item.Id"
                       class="btn btn-info btn-sm">
                        👁 Chi tiết
                    </a>

                    <a asp-action="UpdateStatus"
                       asp-route-id="@item.Id"
                       asp-route-status="Đang giao"
                       class="btn btn-primary btn-sm">
                        Giao hàng
                    </a>

                    <a asp-action="UpdateStatus"
                       asp-route-id="@item.Id"
                       asp-route-status="Hoàn thành"
                       class="btn btn-success btn-sm">
                        Hoàn thành
                    </a>

                </td>

            </tr>
        }

    </tbody>
</table>