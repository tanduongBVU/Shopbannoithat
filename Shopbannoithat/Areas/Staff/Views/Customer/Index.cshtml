@{
}


@model List<Shopbannoithat.Models.User>

<h2>Tư vấn khách hàng</h2>

<table class="table table-bordered">

    <thead>
        <tr>
            <th>Email</th>
            <th>Số điện thoại</th>
            <th>Thao tác</th>
        </tr>
    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Email</td>


                <td>@item.Phone</td>

                <td>

                    <!-- Chat Zalo -->
                    <a href="https://zalo.me/@item.Phone"
                       target="_blank"
                       class="btn btn-primary btn-sm">
                        Chat Zalo
                    </a>

                    <!-- Gọi điện -->
                    <a href="tel:@item.Phone"
                       class="btn btn-success btn-sm">
                        Gọi điện
                    </a>

                </td>
            </tr>
        }

    </tbody>

</table>