@model Shopbannoithat.Models.Product
@using System.Text.Json

@using System.Linq
@{
    Layout = "~/Areas/Staff/Views/Shared/_LayoutStaff.cshtml";

    var allCategories = ViewBag.Categories as List<Shopbannoithat.Models.Category>;
    var currentCategory = allCategories?.FirstOrDefault(c => c.Id == Model.CategoryId);
    var currentParentId = currentCategory?.ParentId ?? currentCategory?.Id;

    var sizes = ViewBag.Sizes as List<Shopbannoithat.Models.ProductSize>;
    var materials = ViewBag.Materials as List<Shopbannoithat.Models.ProductMaterial>;
    var colors = ViewBag.Colors as List<Shopbannoithat.Models.ProductColor>;

    // 🔥 FIX VARIANT JSON
    var variantData = (Model.Variants != null
        ? Model.Variants.Select(v => new
        {
            sizeId = v.SizeId,
            materialId = v.MaterialId,
            colorId = v.ColorId,
            price = v.Price,
            stock = v.Stock
        }).Cast<object>().ToList()
        : new List<object>());

    var variantJson = JsonSerializer.Serialize(variantData);
}


<h2>Sửa sản phẩm</h2>

<form asp-area="Staff" asp-controller="Product" asp-action="Edit" method="post" enctype="multipart/form-data">

    <input type="hidden" asp-for="Id" />

    <div class="mb-3">
        <label>Tên sản phẩm</label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    @* <div class="mb-3">
        <label>Giá</label>
        <input asp-for="Price" class="form-control" />
        <span asp-validation-for="Price" class="text-danger"></span>
    </div> *@

    <div class="mb-3">
        <label class="form-label">Ảnh sản phẩm</label>
        <input type="file" name="imageFile" class="form-control" />
        <span asp-validation-for="Image" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label>Phòng</label>
        <select id="parentSelect" class="form-control" onchange="loadChildren(this.value)">
            <option value="">-- Chọn phòng --</option>
            @foreach (var p in ViewBag.Parents)
            {
                @if (p.Id == currentParentId)
                {
                    <option value="@p.Id" selected>@p.Name</option>
                }
                else
                {
                    <option value="@p.Id">@p.Name</option>
                }
            }
        </select>
    </div>

    <div class="mb-3">
        <label>Loại sản phẩm</label>
        <select name="CategoryId" id="childSelect" class="form-control">
            <option value="">-- Chọn loại --</option>
        </select>
        <span asp-validation-for="CategoryId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label>Số lượng</label>
        <input asp-for="Quantity" class="form-control" />
        <span asp-validation-for="Quantity" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label>Mô tả</label>
        <textarea asp-for="Description" class="form-control"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>


    <!-- BIẾN THỂ -->
    <div class="mb-3">
        <label class="form-label fw-bold">Biến thể sản phẩm</label>
        <div id="variantList"></div>

    </div>
    <div>
        <button type="button" onclick="addVariant()"
                style="background:#4facfe;color:#fff;border:none;padding:8px 16px;border-radius:8px;cursor:pointer;margin-top:8px;">
            + Thêm biến thể
        </button>
    </div>
   

    <button class="btn btn-success">Lưu</button>
    <a asp-area="Staff" asp-controller="Product" asp-action="Index" class="btn btn-secondary ms-2">Quay lại</a>

</form>



@section Scripts {
    <script>
            var allChildren = @Html.Raw(ViewBag.ChildrenJson);
            var currentCategoryId = @Model.CategoryId;

            function loadChildren(parentId, selectedId) {
                var select = document.getElementById('childSelect');
                select.innerHTML = '<option value="">-- Chọn loại --</option>';

                var filtered = allChildren.filter(c => c.parentId == parentId);

                filtered.forEach(c => {
                    let selected = (c.id == selectedId) ? 'selected' : '';
                    select.innerHTML += `<option value="${c.id}" ${selected}>${c.name}</option>`;
                });
            }

            // load category
            var initialParent = document.getElementById('parentSelect').value;
            if (initialParent) loadChildren(initialParent, currentCategoryId);

            document.getElementById('parentSelect').addEventListener('change', function () {
                loadChildren(this.value, null);
            });

            // 🔥 DATA
            const sizes     = @Html.Raw(JsonSerializer.Serialize(ViewBag.Sizes ?? new List<object>()));
            const materials = @Html.Raw(JsonSerializer.Serialize(ViewBag.Materials ?? new List<object>()));
            const colors    = @Html.Raw(JsonSerializer.Serialize(ViewBag.Colors ?? new List<object>()));

            // 🔥 FIX QUAN TRỌNG
            const existingVariants = @Html.Raw(variantJson);

            var variantIndex = 0;

            function addVariantWithData(sizeId, materialId, colorId, price, stock) {

            let sizeOpts = sizes.map(s =>
                `<option value="${s.Id}" ${s.Id == sizeId ? 'selected' : ''}>${s.Name}</option>`
            ).join('');

            let materialOpts = materials.map(m =>
                `<option value="${m.Id}" ${m.Id == materialId ? 'selected' : ''}>${m.Name}</option>`
            ).join('');

            let colorOpts = colors.map(c =>
                `<option value="${c.Id}" ${c.Id == colorId ? 'selected' : ''}>${c.Name}</option>`
            ).join('');

            const i = variantIndex++;

            document.getElementById('variantList').insertAdjacentHTML('beforeend', `
                <div class="variant-row" style="display:grid;grid-template-columns:1fr 1fr 1fr 120px 100px 40px;gap:8px;margin-bottom:8px;align-items:center;">

                    <select name="Variants[${i}].SizeId" class="form-control form-control-sm">
                        <option value="">-- Kích thước --</option>
                        ${sizeOpts}
                    </select>

                    <select name="Variants[${i}].MaterialId" class="form-control form-control-sm">
                        <option value="">-- Vật liệu --</option>
                        ${materialOpts}
                    </select>

                    <select name="Variants[${i}].ColorId" class="form-control form-control-sm">
                        <option value="">-- Màu sắc --</option>
                        ${colorOpts}
                    </select>

                    <input name="Variants[${i}].Price" type="number" value="${price}"
                           class="form-control form-control-sm" placeholder="Giá" />

                    <input name="Variants[${i}].Stock" type="number" value="${stock}"
                           class="form-control form-control-sm" placeholder="Tồn kho" />

                    <button type="button" onclick="this.closest('.variant-row').remove()"
                            style="background:#e74c3c;color:#fff;border:none;border-radius:6px;padding:6px 10px;cursor:pointer;">
                        ✕
                    </button>

                </div>
            `);
        }

            function addVariant() {
                addVariantWithData(null, null, null, '', 0);
            }

            // 🔥 LOAD VARIANTS CŨ
            if (existingVariants && existingVariants.length > 0) {
                existingVariants.forEach(v => {
                    addVariantWithData(v.sizeId, v.materialId, v.colorId, v.price, v.stock);
                });
            }

            console.log(existingVariants);
    </script>
}
<style>
    form {
        max-width: 850px;
        margin: 40px auto;
        padding: 40px;
        background: #ffffff;
        border-radius: 20px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.05);
        border: 1px solid #e2e8f0;
    }

    h2 {
        color: #1e293b;
        font-weight: 800;
        font-size: 1.75rem;
        margin-bottom: 30px;
        text-align: center;
        position: relative;
        padding-bottom: 10px;
    }

        h2::after {
            content: "";
            position: absolute;
            bottom: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 60px;
            height: 4px;
            background: linear-gradient(90deg, #10b981, #3b82f6);
            border-radius: 2px;
        }

    form label {
        display: block;
        font-weight: 700;
        color: #475569;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 8px;
        padding-left: 4px;
    }

    .form-control {
        border-radius: 12px;
        padding: 12px 16px;
        border: 2px solid #f1f5f9;
        background-color: #f8fafc;
        color: #1e293b;
        font-size: 0.95rem;
        transition: all 0.3s ease;
    }

        .form-control:focus {
            background-color: #ffffff;
            border-color: #10b981;
            box-shadow: 0 0 0 4px rgba(16,185,129,0.1);
            outline: none;
        }

    input[type="file"].form-control {
        padding: 8px;
        background: #f0fdf4;
        border: 2px dashed #cbd5e1;
    }

    textarea.form-control {
        min-height: 150px;
        line-height: 1.6;
    }

    .text-danger {
        font-size: 0.8rem;
        font-weight: 600;
        color: #ef4444 !important;
        margin-top: 6px;
        display: block;
    }

    .btn {
        padding: 12px 30px;
        border-radius: 12px;
        font-weight: 700;
        font-size: 0.95rem;
        transition: all 0.3s;
        border: none;
    }

    .btn-success {
        background: linear-gradient(135deg, #10b981, #059669);
        color: white;
        box-shadow: 0 4px 12px rgba(16,185,129,0.3);
    }

        .btn-success:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(16,185,129,0.4);
        }

    .btn-secondary {
        background-color: #f1f5f9;
        color: #64748b;
    }

        .btn-secondary:hover {
            background-color: #e2e8f0;
            color: #1e293b;
            transform: translateY(-2px);
        }

    .mb-3 {
        margin-bottom: 1.5rem !important;
    }
</style>