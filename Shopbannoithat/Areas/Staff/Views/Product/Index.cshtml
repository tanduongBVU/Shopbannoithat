@{
}


@model List<Shopbannoithat.Models.Product>

<h2>Danh sách sản phẩm</h2>

<table class="table table-bordered">

    <thead>
        <tr>
            <th>Sản phẩm</th>
            <th>Giá</th>
            <th>Tồn kho</th>
            <th>Xem</th>
        </tr>
    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>

                <td>@item.Price?.ToString("N0") VNĐ</td>

                <td>@item.Quantity</td>

                <td>
                    <a asp-action="Detail"
                       asp-route-id="@item.Id"
                       class="btn btn-info btn-sm">
                        Xem chi tiết
                    </a>
                </td>
            </tr>
        }

    </tbody>

</table>