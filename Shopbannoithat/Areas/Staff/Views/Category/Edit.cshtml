@{
}

@model Shopbannoithat.Models.Category

<style>
    /* ===== FORM EDIT CATEGORY ===== */
    .edit-category-container {
        max-width: 600px;
        margin: 50px auto;
        background: #ffffff;
        padding: 32px;
        border-radius: 18px;
        box-shadow: 0 15px 40px rgba(0,0,0,0.12);
        border-top: 6px solid #6c5ce7;
    }

    /* TITLE */
    .edit-category-title {
        text-align: center;
        font-weight: 700;
        margin-bottom: 25px;
        color: #2d3436;
    }

    /* LABEL */
    .edit-category-container label {
        font-weight: 600;
        color: #2d3436;
    }

    /* INPUT */
    .edit-category-container .form-control {
        border-radius: 10px;
        padding: 12px;
        border: 1px solid #ccc;
        transition: 0.25s;
    }

        /* focus */
        .edit-category-container .form-control:focus {
            border-color: #6c5ce7;
            box-shadow: 0 0 0 3px rgba(108,92,231,0.25);
        }

    /* BUTTON GROUP */
    .edit-category-actions {
        margin-top: 20px;
        display: flex;
        gap: 10px;
    }

    /* BUTTON SAVE */
    .btn-save-edit {
        background: linear-gradient(90deg, #0984e3, #6c5ce7);
        border: none;
        color: #fff;
        font-weight: 600;
        border-radius: 10px;
        padding: 10px 18px;
        transition: 0.3s;
    }

        .btn-save-edit:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(0,0,0,0.2);
        }

    /* BUTTON BACK */
    .btn-back-edit {
        background: #636e72;
        color: #fff;
        border-radius: 10px;
        padding: 10px 18px;
        transition: 0.3s;
    }

        .btn-back-edit:hover {
            background: red;
            transform: translateY(-2px);
        }

    /* VALIDATION */
    .text-danger {
        font-size: 13px;
        margin-top: 4px;
        display: block;
    }
</style>

<div class="edit-category-container">

    <h2 class="edit-category-title">✏️ Sửa loại sản phẩm</h2>

    <form asp-area="Staff" asp-controller="Category" asp-action="Edit" method="post">

        <input type="hidden" asp-for="Id" />

        <div class="mb-3">
            <label>Tên loại</label>
            <input asp-for="Name" class="form-control"
                   placeholder="Nhập tên loại..." />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label>Mô tả</label>
            <input asp-for="Description" class="form-control"
                   placeholder="Nhập mô tả..." />
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <div class="edit-category-actions">
            <button class="btn btn-save-edit">
                💾 Lưu
            </button>

            <a asp-area="Staff" asp-controller="Category" asp-action="Index" class="btn btn-back-edit">
                ← Quay lại
            </a>
        </div>

    </form>

</div>

