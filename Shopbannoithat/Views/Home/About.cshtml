@{
    ViewData["Title"] = "Giới thiệu";
}

@* ===== HERO BANNER ===== *@
<div class="about-hero">
    <div class="about-hero-overlay">
        <h1>Về ShopNoiThat</h1>
        <p>Kiến tạo không gian sống — Truyền cảm hứng từ nội thất</p>
    </div>
</div>

@* ===== GIỚI THIỆU CÔNG TY ===== *@
<section class="about-section py-5">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-md-6">
                <span class="about-label">Câu chuyện của chúng tôi</span>
                <h2 class="about-title">ShopNoiThat — Hơn 10 năm kiến tạo không gian sống</h2>
                <p class="about-text">
                    ShopNoiThat được thành lập từ năm 2015 với mong muốn mang đến những sản phẩm
                    nội thất chất lượng cao, thiết kế hiện đại nhưng vẫn gần gũi với người Việt.
                </p>
                <p class="about-text">
                    Chúng tôi tin rằng một không gian sống đẹp không chỉ là xa xỉ — đó là nhu cầu
                    thiết yếu giúp bạn và gia đình cảm thấy thoải mái, hạnh phúc mỗi ngày.
                </p>
                <div class="d-flex gap-3 mt-4">
                    <a asp-controller="Product" asp-action="Index" class="btn-about-primary">Xem sản phẩm</a>
                    <a asp-controller="Contact" asp-action="Index" class="btn-about-outline">Liên hệ ngay</a>
                </div>
            </div>
            <div class="col-md-6">
                <div class="about-img-wrap">
                    <img src="~/images/khach-s-n-senkotel-nha.jpg" alt="ShopNoiThat" />
                </div>
            </div>
        </div>
    </div>
</section>

@* ===== THÀNH TỰU ===== *@
<section class="stats-section py-5">
    <div class="container">
        <div class="row g-4 text-center">
            <div class="col-6 col-md-3">
                <div class="stat-card">
                    <div class="stat-number">10+</div>
                    <div class="stat-label">Năm kinh nghiệm</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-card">
                    <div class="stat-number">5,000+</div>
                    <div class="stat-label">Khách hàng hài lòng</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-card">
                    <div class="stat-number">500+</div>
                    <div class="stat-label">Sản phẩm đa dạng</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-card">
                    <div class="stat-number">63</div>
                    <div class="stat-label">Tỉnh thành giao hàng</div>
                </div>
            </div>
        </div>
    </div>
</section>

@* ===== TẦM NHÌN & SỨ MỆNH ===== *@
<section class="vision-section py-5">
    <div class="container">
        <div class="text-center mb-5">
            <span class="about-label">Định hướng phát triển</span>
            <h2 class="about-title">Tầm nhìn & Sứ mệnh</h2>
        </div>
        <div class="row g-4">
            <div class="col-md-6">
                <div class="vision-card">
                    <div class="vision-icon">🎯</div>
                    <h4>Tầm nhìn</h4>
                    <p>
                        Trở thành thương hiệu nội thất được tin yêu hàng đầu Việt Nam —
                        nơi mỗi sản phẩm là một cam kết về chất lượng, thẩm mỹ và sự bền vững.
                    </p>
                </div>
            </div>
            <div class="col-md-6">
                <div class="vision-card">
                    <div class="vision-icon">💡</div>
                    <h4>Sứ mệnh</h4>
                    <p>
                        Mang đến giải pháp nội thất toàn diện, giúp mỗi gia đình Việt
                        có được không gian sống đẹp, tiện nghi với mức giá hợp lý nhất.
                    </p>
                </div>
            </div>
            <div class="col-md-6">
                <div class="vision-card">
                    <div class="vision-icon">🌱</div>
                    <h4>Giá trị cốt lõi</h4>
                    <p>
                        Chất lượng — Trung thực — Sáng tạo — Tận tâm.
                        Đây là 4 giá trị định hướng mọi hoạt động của ShopNoiThat.
                    </p>
                </div>
            </div>
            <div class="col-md-6">
                <div class="vision-card">
                    <div class="vision-icon">🤝</div>
                    <h4>Cam kết</h4>
                    <p>
                        Bảo hành chính hãng, hỗ trợ sau bán hàng tận tình,
                        đổi trả linh hoạt trong 30 ngày nếu sản phẩm có lỗi từ nhà sản xuất.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

@* ===== TẠI SAO CHỌN CHÚNG TÔI ===== *@
<section class="why-section py-5">
    <div class="container">
        <div class="text-center mb-5">
            <span class="about-label">Lợi ích</span>
            <h2 class="about-title">Tại sao chọn ShopNoiThat?</h2>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="why-card">
                    <div class="why-icon">🏆</div>
                    <h5>Chất lượng đảm bảo</h5>
                    <p>100% sản phẩm được kiểm định chất lượng trước khi đến tay khách hàng.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="why-card">
                    <div class="why-icon">🚚</div>
                    <h5>Giao hàng toàn quốc</h5>
                    <p>Giao hàng nhanh chóng, đóng gói cẩn thận đến 63 tỉnh thành trên cả nước.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="why-card">
                    <div class="why-icon">💰</div>
                    <h5>Giá cả hợp lý</h5>
                    <p>Cam kết giá tốt nhất thị trường, nhiều chương trình ưu đãi hấp dẫn.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="why-card">
                    <div class="why-icon">🛡️</div>
                    <h5>Bảo hành chính hãng</h5>
                    <p>Bảo hành từ 12 đến 36 tháng tùy sản phẩm, hỗ trợ đổi trả dễ dàng.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="why-card">
                    <div class="why-icon">📞</div>
                    <h5>Hỗ trợ 24/7</h5>
                    <p>Đội ngũ tư vấn luôn sẵn sàng hỗ trợ bạn mọi lúc, mọi nơi.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="why-card">
                    <div class="why-icon">✨</div>
                    <h5>Thiết kế đa dạng</h5>
                    <p>Hàng trăm mẫu mã phong cách từ hiện đại, tối giản đến cổ điển sang trọng.</p>
                </div>
            </div>
        </div>
    </div>
</section>

@* ===== ĐỘI NGŨ ===== *@
<section class="team-section py-5">
    <div class="container">
        <div class="text-center mb-5">
            <span class="about-label">Con người</span>
            <h2 class="about-title">Đội ngũ của chúng tôi</h2>
            <p class="about-text mx-auto" style="max-width:600px;">
                Những con người tâm huyết, luôn nỗ lực mang đến trải nghiệm tốt nhất cho khách hàng.
            </p>
        </div>
        <div class="row g-4 justify-content-center">
            <div class="col-6 col-md-3">
                <div class="team-card">
                    <div class="team-avatar">👨‍💼</div>
                    <h6>Nguyễn Văn An</h6>
                    <span>Giám đốc điều hành</span>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="team-card">
                    <div class="team-avatar">👩‍🎨</div>
                    <h6>Trần Thị Bình</h6>
                    <span>Giám đốc thiết kế</span>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="team-card">
                    <div class="team-avatar">👨‍💻</div>
                    <h6>Lê Minh Cường</h6>
                    <span>Trưởng phòng kỹ thuật</span>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="team-card">
                    <div class="team-avatar">👩‍💼</div>
                    <h6>Phạm Thị Dung</h6>
                    <span>Trưởng phòng kinh doanh</span>
                </div>
            </div>
        </div>
    </div>
</section>

@* ===== CTA ===== *@
<section class="cta-section py-5">
    <div class="container text-center">
        <h2>Sẵn sàng kiến tạo không gian sống của bạn?</h2>
        <p>Khám phá hàng trăm sản phẩm nội thất chất lượng cao tại ShopNoiThat</p>
        <a href="/Product" class="btn-about-primary me-3">Mua sắm ngay</a>
        <a href="/Contact" class="btn-about-outline">Liên hệ tư vấn</a>
    </div>
</section>

@* ===== CSS ===== *@
<style>
    /* Hero */
    .about-hero {
        width: 100%;
        height: 350px;
        background: linear-gradient(135deg, #3a2a1a 0%, #7a4f2d 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        margin-top: -16px;
    }

    .about-hero-overlay {
        text-align: center;
        color: #fff;
    }

        .about-hero-overlay h1 {
            font-size: 2.8rem;
            font-weight: 800;
            margin-bottom: 12px;
            text-shadow: 0 2px 8px rgba(0,0,0,0.3);
        }

        .about-hero-overlay p {
            font-size: 1.15rem;
            color: #f0e6d8;
        }

    /* Labels & Titles */
    .about-label {
        display: inline-block;
        background: #fdf0ea;
        color: #e05c2a;
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        padding: 5px 14px;
        border-radius: 20px;
        margin-bottom: 14px;
    }

    .about-title {
        font-size: 1.8rem;
        font-weight: 700;
        color: #2c1e10;
        margin-bottom: 16px;
    }

    .about-text {
        color: #6b5a4a;
        line-height: 1.8;
        font-size: 0.95rem;
    }

    /* Buttons */
    .btn-about-primary {
        display: inline-block;
        background: #3a2a1a;
        color: #fff;
        padding: 10px 28px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.9rem;
        transition: background 0.2s;
    }

        .btn-about-primary:hover {
            background: #7a4f2d;
            color: #fff;
        }

    .btn-about-outline {
        display: inline-block;
        border: 2px solid #3a2a1a;
        color: #3a2a1a;
        padding: 10px 28px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.9rem;
        transition: all 0.2s;
    }

        .btn-about-outline:hover {
            background: #3a2a1a;
            color: #fff;
        }

    /* Image */
    .about-img-wrap {
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 12px 40px rgba(90,50,20,0.15);
    }

        .about-img-wrap img {
            width: 100%;
            height: 380px;
            object-fit: cover;
        }

    /* Stats */
    .stats-section {
        background: linear-gradient(135deg, #3a2a1a, #6b4f3b);
    }

    .stat-card {
        padding: 30px 20px;
        color: #fff;
    }

    .stat-number {
        font-size: 2.8rem;
        font-weight: 800;
        color: #f5c67a;
        line-height: 1;
        margin-bottom: 8px;
    }

    .stat-label {
        font-size: 0.9rem;
        color: #d4c4b4;
    }

    /* Vision */
    .vision-section {
        background: #f8f5f0;
    }

    .vision-card {
        background: #fff;
        border-radius: 14px;
        padding: 28px;
        height: 100%;
        border: 1px solid #ece8e1;
        transition: box-shadow 0.25s, transform 0.25s;
    }

        .vision-card:hover {
            box-shadow: 0 8px 28px rgba(90,50,20,0.12);
            transform: translateY(-4px);
        }

    .vision-icon {
        font-size: 2.2rem;
        margin-bottom: 14px;
    }

    .vision-card h4 {
        font-size: 1.1rem;
        font-weight: 700;
        color: #2c1e10;
        margin-bottom: 10px;
    }

    .vision-card p {
        color: #6b5a4a;
        font-size: 0.9rem;
        line-height: 1.7;
        margin: 0;
    }

    /* Why */
    .why-section {
        background: #fff;
    }

    .why-card {
        text-align: center;
        padding: 28px 20px;
        border-radius: 14px;
        border: 1px solid #ece8e1;
        height: 100%;
        transition: box-shadow 0.25s, transform 0.25s;
    }

        .why-card:hover {
            box-shadow: 0 8px 28px rgba(90,50,20,0.12);
            transform: translateY(-4px);
            border-color: #e05c2a;
        }

    .why-icon {
        font-size: 2.4rem;
        margin-bottom: 14px;
    }

    .why-card h5 {
        font-size: 1rem;
        font-weight: 700;
        color: #2c1e10;
        margin-bottom: 10px;
    }

    .why-card p {
        color: #6b5a4a;
        font-size: 0.88rem;
        line-height: 1.7;
        margin: 0;
    }

    /* Team */
    .team-section {
        background: #f8f5f0;
    }

    .team-card {
        text-align: center;
        padding: 28px 16px;
        background: #fff;
        border-radius: 14px;
        border: 1px solid #ece8e1;
        transition: box-shadow 0.25s, transform 0.25s;
    }

        .team-card:hover {
            box-shadow: 0 8px 24px rgba(90,50,20,0.12);
            transform: translateY(-4px);
        }

    .team-avatar {
        font-size: 3.5rem;
        margin-bottom: 14px;
        width: 80px;
        height: 80px;
        background: #f8f5f0;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 14px;
    }

    .team-card h6 {
        font-weight: 700;
        color: #2c1e10;
        margin-bottom: 4px;
        font-size: 0.95rem;
    }

    .team-card span {
        font-size: 0.82rem;
        color: #9e8672;
    }

    /* CTA */
    .cta-section {
        background: linear-gradient(135deg, #3a2a1a, #7a4f2d);
        color: #fff;
    }

        .cta-section h2 {
            font-size: 2rem;
            font-weight: 700;
            margin-bottom: 12px;
        }

        .cta-section p {
            color: #d4c4b4;
            margin-bottom: 28px;
        }
</style>