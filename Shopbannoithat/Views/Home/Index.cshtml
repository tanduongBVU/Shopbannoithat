<script src="https://code.jquery.com/jquery-3.6.0.min.js"> </script>
<script>
         $(document).on("click", ".addWishlist", function () {
        var productId = $(this).data("id");
        var btn = $(this);
        $.post("/Wishlist/Add/" + productId, function (data) {
            if (data.success == false) {
                window.location = "/Auth/Login";
            } else {
                // Toggle active
                if (data.isAdded) {
                    btn.addClass("active");
                } else {
                    btn.removeClass("active");
                }
                // Cập nhật số đếm wishlist trên navbar
                $("#wishlist-count").text(data.count);
            }
        });
    });
</script>


<script>
    document.querySelectorAll(".product-slider").forEach(sliderWrap => {

        let index = 0;

        const slider = sliderWrap.querySelector(".row");
        const items = sliderWrap.querySelectorAll(".col-lg-3");
        const btnLeft = sliderWrap.querySelector(".slider-btn.left");
        const btnRight = sliderWrap.querySelector(".slider-btn.right");

        if (items.length === 0) return;

        // 👉 lấy width thật
        const itemWidth = items[0].offsetWidth;

        // 👉 số item hiển thị
        const visibleItems = Math.floor(sliderWrap.offsetWidth / itemWidth);

        // 👉 giới hạn
        const maxIndex = items.length - visibleItems;

        // 👉 auto chạy
        let autoSlide = setInterval(() => {
            index++;
            if (index > maxIndex) index = 0;
            slider.style.transform = `translateX(-${index * itemWidth}px)`;
        }, 3000);

        // 👉 nút phải
        btnRight.onclick = () => {
            index++;
            if (index > maxIndex) index = maxIndex;
            slider.style.transform = `translateX(-${index * itemWidth}px)`;
        };

        // 👉 nút trái
        btnLeft.onclick = () => {
            index--;
            if (index < 0) index = 0;
            slider.style.transform = `translateX(-${index * itemWidth}px)`;
        };

        // 👉 dừng auto khi hover (xịn hơn)
        sliderWrap.addEventListener("mouseenter", () => clearInterval(autoSlide));
        sliderWrap.addEventListener("mouseleave", () => {
            autoSlide = setInterval(() => {
                index++;
                if (index > maxIndex) index = 0;
                slider.style.transform = `translateX(-${index * itemWidth}px)`;
            }, 3000);
        });

    });

    
</script>
