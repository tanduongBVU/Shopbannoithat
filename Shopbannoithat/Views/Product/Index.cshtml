<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    const sortToggle = document.getElementById('sortToggle');
    const sortMenu = document.getElementById('sortMenu');
    const chevron = document.querySelector('.sort-chevron');

    sortToggle.addEventListener('click', function (e) {
        e.stopPropagation();
        const isOpen = sortMenu.classList.toggle('show');
        sortToggle.classList.toggle('open', isOpen);
        chevron.classList.toggle('open', isOpen);
    });

    document.addEventListener('click', function () {
        sortMenu.classList.remove('show');
        sortToggle.classList.remove('open');
        chevron.classList.remove('open');
    });

    $(document).on("click", ".addWishlist", function () {
        var btn = $(this);
        var productId = btn.data("id");
        $.post("/Wishlist/Add/" + productId, function (data) {
            if (data.success == false) { window.location = "/Auth/Login"; return; }
            $("#wishlist-count").text(data.count);
            if (data.isAdded) {
                btn.css("color", "#e05c2a");
                btn.find("i").removeClass("bi-heart").addClass("bi-heart-fill");
            } else {
                btn.css("color", "#aaa");
                btn.find("i").removeClass("bi-heart-fill").addClass("bi-heart");
            }
        });
    });

    $.get("/Wishlist/GetUserWishlist", function (ids) {
        ids.forEach(function (id) {
            var btn = $(".addWishlist[data-id='" + id + "']");
            btn.css("color", "#e05c2a");
            btn.find("i").removeClass("bi-heart").addClass("bi-heart-fill");
        });
    });
</script>