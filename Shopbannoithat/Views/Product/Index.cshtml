@model List<Shopbannoithat.Models.Product>

@{
    var currentSort = ViewBag.CurrentSort as string;
    var sortLabel = currentSort switch
    {
        "newest" => "Mới nhất",
        "price_asc" => "Giá thấp → cao",
        "price_desc" => "Giá cao → thấp",
        _ => "Sắp xếp theo"
    };
}

<div class="container py-4">

    <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
        <h2 class="mb-0">Danh sách sản phẩm</h2>

        <div class="sort-dropdown">
            <button class="sort-btn" id="sortToggle">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="21" y1="10" x2="7" y2="10"></line>
                    <line x1="21" y1="6" x2="3" y2="6"></line>
                    <line x1="21" y1="14" x2="3" y2="14"></line>
                    <line x1="21" y1="18" x2="7" y2="18"></line>
                </svg>
                <span id="sortLabelText">@sortLabel</span>
                <svg class="sort-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
            </button>

            <div class="sort-menu" id="sortMenu">
                <div class="sort-menu-header">Sắp xếp theo</div>

                <a href="/Product" class="sort-item @(string.IsNullOrEmpty(currentSort) ? "active" : "")">
                    <span class="sort-item-icon">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"></circle>
                        </svg>
                    </span>
                    Mặc định
                    @if (string.IsNullOrEmpty(currentSort))
                    {
                        <span class="sort-check">✓</span>
                    }
                </a>

                <a href="/Product?sort=newest" class="sort-item @(currentSort == "newest" ? "active" : "")">
                    <span class="sort-item-icon">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="23 6 13.5 15.5 8.5 10.5 1 18"></polyline>
                            <polyline points="17 6 23 6 23 12"></polyline>
                        </svg>
                    </span>
                    Mới nhất
                    @if (currentSort == "newest")
                    {
                        <span class="sort-check">✓</span>
                    }
                </a>

                <a href="/Product?sort=price_asc" class="sort-item @(currentSort == "price_asc" ? "active" : "")">
                    <span class="sort-item-icon">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="12" y1="19" x2="12" y2="5"></line>
                            <polyline points="5 12 12 5 19 12"></polyline>
                        </svg>
                    </span>
                    Giá thấp → cao
                    @if (currentSort == "price_asc")
                    {
                        <span class="sort-check">✓</span>
                    }
                </a>

                <a href="/Product?sort=price_desc" class="sort-item @(currentSort == "price_desc" ? "active" : "")">
                    <span class="sort-item-icon">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="12" y1="5" x2="12" y2="19"></line>
                            <polyline points="19 12 12 19 5 12"></polyline>
                        </svg>
                    </span>
                    Giá cao → thấp
                    @if (currentSort == "price_desc")
                    {
                        <span class="sort-check">✓</span>
                    }
                </a>
            </div>
        </div>
    </div>

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-3 mb-4">
                <div class="card h-100 shadow-sm">
                    <img src="~/images/@item.Image"
                         class="card-img-top"
                         style="height:220px; object-fit:cover;">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@item.Name</h5>
                        <p class="text-danger fw-bold">
                            @item.Price?.ToString("N0") VNĐ
                        </p>
                        <div class="mt-auto">
                            <a asp-controller="Product"
                               asp-action="Details"
                               asp-route-id="@item.Id"
                               class="btn btn-info">
                                Xem chi tiết
                            </a>

                            @if (Context.Session.GetString("UserEmail") != null)
                            {
                                @if (item.Quantity > 0)
                                {
                                    <a asp-controller="Cart" asp-action="Add"
                                       asp-route-id="@item.Id"
                                       class="btn btn-success">
                                        Thêm giỏ
                                    </a>
                                }
                                else
                                {
                                    <button class="btn btn-danger" disabled>Hết hàng</button>
                                }
                            }
                            else
                            {
                                <a asp-controller="Auth" asp-action="Login"
                                   class="btn btn-warning btn-sm">
                                    Đăng nhập để mua
                                </a>
                            }

                            @if (Context.Session.GetString("UserEmail") != null)
                            {
                                <button class="btn btn-danger addWishlist"
                                        data-id="@item.Id">
                                    ❤ Wishlist
                                </button>
                            }
                            else
                            {
                                <a asp-controller="Auth" asp-action="Login"
                                   class="btn btn-danger">
                                    ❤ Wishlist
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .sort-dropdown {
        position: relative;
        display: inline-block;
    }

    .sort-btn {
        display: flex;
        align-items: center;
        gap: 7px;
        padding: 9px 16px;
        border-radius: 10px;
        font-size: 0.88rem;
        font-weight: 500;
        color: #3a2a1a;
        background: #fff;
        border: 1.5px solid #d6cfc6;
        cursor: pointer;
        transition: all 0.2s;
        white-space: nowrap;
    }

        .sort-btn:hover, .sort-btn.open {
            border-color: #3a2a1a;
            background: #faf8f5;
        }

    .sort-chevron {
        transition: transform 0.22s;
        opacity: 0.6;
    }

        .sort-chevron.open {
            transform: rotate(180deg);
        }

    .sort-menu {
        display: none;
        position: absolute;
        right: 0;
        top: calc(100% + 8px);
        background: #fff;
        border: 1.5px solid #e8e2da;
        border-radius: 12px;
        min-width: 210px;
        z-index: 999;
        box-shadow: 0 8px 24px rgba(58,42,26,0.12);
        overflow: hidden;
    }

        .sort-menu.show {
            display: block;
            animation: dropIn 0.18s ease;
        }

    @@keyframes dropIn {
        from {
            opacity: 0;
            transform: translateY(-6px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .sort-menu-header {
        padding: 10px 16px 8px;
        font-size: 0.72rem;
        font-weight: 600;
        color: #9e8e7e;
        text-transform: uppercase;
        letter-spacing: 0.7px;
        border-bottom: 1px solid #f0ece6;
    }

    .sort-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 16px;
        font-size: 0.88rem;
        color: #3a2a1a;
        text-decoration: none;
        transition: background 0.15s;
    }

        .sort-item:hover {
            background: #faf7f3;
            color: #3a2a1a;
        }

        .sort-item.active {
            background: #faf7f3;
            font-weight: 600;
            color: #3a2a1a;
        }

    .sort-item-icon {
        display: flex;
        align-items: center;
        color: #9e8e7e;
        flex-shrink: 0;
    }

    .sort-item.active .sort-item-icon {
        color: #7a4f2d;
    }

    .sort-check {
        margin-left: auto;
        color: #7a4f2d;
        font-weight: 700;
        font-size: 0.85rem;
    }
</style>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    const sortToggle = document.getElementById('sortToggle');
    const sortMenu = document.getElementById('sortMenu');
    const chevron = document.querySelector('.sort-chevron');

    sortToggle.addEventListener('click', function (e) {
        e.stopPropagation();
        const isOpen = sortMenu.classList.toggle('show');
        sortToggle.classList.toggle('open', isOpen);
        chevron.classList.toggle('open', isOpen);
    });

    document.addEventListener('click', function () {
        sortMenu.classList.remove('show');
        sortToggle.classList.remove('open');
        chevron.classList.remove('open');
    });

    $(document).on("click", ".addWishlist", function () {
        var productId = $(this).data("id");
        $.post("/Wishlist/Add/" + productId, function (data) {
            if (data.success == false) {
                window.location = "/Auth/Login";
            } else {
                window.location = "/Wishlist";
            }
        });
    });
</script>