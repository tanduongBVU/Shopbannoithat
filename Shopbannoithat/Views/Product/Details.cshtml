@model Shopbannoithat.Models.Product
@{
    var userEmail = Context.Session.GetString("UserEmail");
}

<div class="container py-4">
    <div class="row g-4">

        <div class="col-md-5">
            <div style="border-radius:16px; overflow:hidden; background:#f5f0eb;">
                <img src="~/images/@Model.Image"
                     class="img-fluid w-100"
                     style="max-height:420px; object-fit:cover;"
                     alt="@Model.Name" />
            </div>
        </div>

        <div class="col-md-7 d-flex flex-column justify-content-center">
            <p style="font-size:0.75rem; font-weight:600; text-transform:uppercase;
            letter-spacing:1px; color:#9e8e7e; margin-bottom:6px;">Nội thất</p>

            <h3 style="font-weight:700; color:#2a1f14; margin-bottom:10px;">@Model.Name</h3>

            <h4 style="font-weight:700; color:#e05c2a; margin-bottom:14px;">
                @Model.Price?.ToString("N0") ₫
            </h4>

            <p style="color:#666; line-height:1.7; margin-bottom:24px;">@Model.Description</p>

            <div class="d-flex gap-3 align-items-center flex-wrap">

                @if (userEmail != null)
                {
                    @if (Model.Quantity > 0)
                    {
                        <a asp-controller="Cart" asp-action="Add"
                               asp-route-id="@Model.Id"
                               style="padding:12px 28px; background:#e05c2a; color:#fff;
                            border-radius:10px; font-weight:600; text-decoration:none;
                            font-size:0.95rem; display:flex; align-items:center; gap:8px;"
                               onmouseover="this.style.background='#c44e22'"
                               onmouseout="this.style.background='#e05c2a'">
                            <i class="bi bi-cart-plus"></i> Thêm vào giỏ
                        </a>
                    }
                    else
                    {
                        <button disabled
                                style="padding:12px 28px; background:#ccc; color:#fff;
                            border-radius:10px; font-weight:600; border:none;
                            font-size:0.95rem; cursor:not-allowed;">
                            Hết hàng
                        </button>
                    }
                }
                else
                {
                    <a asp-controller="Auth" asp-action="Login"
                           style="padding:12px 28px; background:#e05c2a; color:#fff;
                        border-radius:10px; font-weight:600; text-decoration:none;
                        font-size:0.95rem; display:flex; align-items:center; gap:8px;">
                        <i class="bi bi-cart-plus"></i> Đăng nhập để mua
                    </a>
                }

                <a asp-controller="Product" asp-action="Index"
                       style="padding:12px 24px; background:#2a1f14; color:#fff;
                    border-radius:10px; font-weight:600; text-decoration:none;
                    font-size:0.95rem; display:flex; align-items:center; gap:8px;"
                       onmouseover="this.style.background='#3d2e1e'"
                       onmouseout="this.style.background='#2a1f14'">
                    <i class="bi bi-arrow-left"></i> Quay lại
                </a>

            </div>
        </div>

    </div>
</div>