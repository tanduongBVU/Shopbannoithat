@{
}
@model Shopbannoithat.Models.LoginViewModel

<div class="register-page">
<div class="register-card">
    <h2>Đăng nhập</h2>
    <form asp-action="Login" method="post">
        <div class="mb-3">
            <label>Email</label>
            <input asp-for="Email" class="form-control" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>


        <div class="mb-3">
            <label>Mật khẩu</label>
            <input asp-for="Password" type="password" class="form-control" />
            <span asp-validation-for="Password" class="text-danger"></span>
        </div>
            <div class="form-options">
                <div class="remember-me">
                    <input type="checkbox" id="remember">
                    <label for="remember">Ghi nhớ tôi</label>
                </div>
                <a asp-controller="Auth" asp-action="ForgotPassword" class="forgot-link">Quên mật khẩu?</a>
            </div>

            <button type="submit" class="btn-login-glow">
                ĐĂNG NHẬP <i class="fas fa-sign-in-alt"></i>
            </button>

    </form>

        <!-- Divider -->
        <div style="display:flex; align-items:center; gap:10px; margin:20px 0;">
            <hr style="flex:1; border-color:#ddd;">
            <span style="color:#999; font-size:13px;">hoặc</span>
            <hr style="flex:1; border-color:#ddd;">
        </div>

        <!-- Nút Google -->
        <a href="/Auth/LoginGoogle"
               style="display:flex; align-items:center; justify-content:center; gap:10px;
            width:100%; padding:12px; border-radius:12px; border:1.5px solid #ddd;
            background:#fff; color:#333; text-decoration:none; font-size:15px;
            font-weight:500; transition:box-shadow 0.2s;"
               onmouseover="this.style.boxShadow='0 4px 12px rgba(0,0,0,0.1)'"
               onmouseout="this.style.boxShadow='none'">
            <img src="https://www.google.com/favicon.ico" width="20" height="20">
            Đăng nhập bằng Google
        </a>
</div>
</div>


<style>
   

    /* Tổng thể trang đăng ký */
    .register-page {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 80vh;
    }

    /* Thẻ đăng ký */
    .register-card {
        background: #ffffff;
        padding: 50px 40px;
        border-radius: 16px;
        box-shadow: 0 12px 30px rgba(0,0,0,0.25);
        width: 420px;
        border: 1px solid rgba(212,175,55,0.3);
        transition: transform 0.3s ease;
    }

        .register-card:hover {
            transform: translateY(-6px);
        }

        /* Tiêu đề */
        .register-card h2 {
            text-align: center;
            font-size: 28px;
            font-weight: 600;
            color: #5a3e2b;
            margin-bottom: 30px;
        }

        /* Nhóm input */
        .register-card .mb-3 {
            margin-bottom: 22px;
        }

        .register-card label {
            font-weight: 500;
            color: #333;
            margin-bottom: 8px;
            display: block;
        }

        .register-card input {
            border: 1px solid #ccc;
            border-radius: 12px;
            padding: 12px;
            font-size: 15px;
            width: 100%;
            transition: border-color 0.3s, box-shadow 0.3s;
            background: #f9f9f9;
        }

            .register-card input:focus {
                border-color: #d4af37;
                box-shadow: 0 0 10px rgba(212,175,55,0.3);
                outline: none;
            }

        /* Nút đăng ký */
        .register-card .btn {
            background: linear-gradient(135deg, #d4af37, #b8860b);
            border: none;
            color: #fff;
            padding: 14px;
            width: 100%;
            border-radius: 12px;
            font-size: 16px;
            font-weight: bold;
            cursor: pointer;
            letter-spacing: 0.5px;
            transition: transform 0.2s, box-shadow 0.2s;
        }

            .register-card .btn:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 20px #593d2b;
            }


    /* Options */
    .form-options {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 28px;
        font-size: 13px;
    }

        .form-options a {
            color: #2c5364;
            text-decoration: none;
            font-weight: 500;
            transition: color 0.3s;
        }

            .form-options a:hover {
                color: #d4af37;
            }

    /* Nút đăng nhập */
    .btn-login-glow {
        background: linear-gradient(135deg, #d4af37, #b8860b); /* vàng sang trọng */
        border: none;
        color: #fff;
        padding: 14px;
        width: 100%;
        border-radius: 12px;
        font-size: 16px;
        font-weight: bold;
        cursor: pointer;
        letter-spacing: 0.5px;
        transition: transform 0.2s, box-shadow 0.2s;
    }

        .btn-login-glow:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(212,175,55,0.4);
        }

 

        .error-msg i {
            margin-right: 8px;
        }

</style>