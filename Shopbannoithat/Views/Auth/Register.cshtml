@{
}


@model Shopbannoithat.Models.RegisterViewModel

<div class="register-page">
    <div class="register-card">
    <h2>ĐĂNG KÝ</h2>

    <div class="mb-3">
        <label>Email</label>
        <input asp-for="Email" class="form-control" placeholder="Email" />
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label>Số điện thoại</label>
        <input asp-for="Phone" class="form-control" />
    </div>
    <label>Mật khẩu</label>
    <div class="mb-3">
        <input asp-for="Password" type="password" class="form-control" placeholder="Password" />
        <span asp-validation-for="Password" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label>Xác nhận mật khẩu</label>
        <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Confirm Password" />
        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
    </div>

    <button class="btn btn-success">Đăng ký</button>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger">
            @ViewBag.Error
        </div>
    }

    </div>
</div>
<style>
    /* Tổng thể trang đăng ký */
    .register-page {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 80vh;

    }

    /* Thẻ đăng ký */
    .register-card {
        background: #ffffff;
        padding: 50px 40px;
        border-radius: 16px;
        box-shadow: 0 12px 30px rgba(0,0,0,0.25);
        width: 420px;
        border: 1px solid rgba(212,175,55,0.3);
        transition: transform 0.3s ease;
    }

        .register-card:hover {
            transform: translateY(-6px);
        }

        /* Tiêu đề */
        .register-card h2 {
            text-align: center;
            font-size: 28px;
            font-weight: 600;
            color: #5a3e2b;
            margin-bottom: 30px;
        }

        /* Nhóm input */
        .register-card .mb-3 {
            margin-bottom: 22px;
        }

        .register-card label {
            font-weight: 500;
            color: #333;
            margin-bottom: 8px;
            display: block;
        }

        .register-card input {
            border: 1px solid #ccc;
            border-radius: 12px;
            padding: 12px;
            font-size: 15px;
            width: 100%;
            transition: border-color 0.3s, box-shadow 0.3s;
            background: #f9f9f9;
        }

            .register-card input:focus {
                border-color: #d4af37;
                box-shadow: 0 0 10px rgba(212,175,55,0.3);
                outline: none;
            }

        /* Nút đăng ký */
        .register-card .btn {
            background: linear-gradient(135deg, #d4af37, #b8860b);
            border: none;
            color: #fff;
            padding: 14px;
            width: 100%;
            border-radius: 12px;
            font-size: 16px;
            font-weight: bold;
            cursor: pointer;
            letter-spacing: 0.5px;
            transition: transform 0.2s, box-shadow 0.2s;
        }

            .register-card .btn:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 20px #593d2b;
            }

    /* Thông báo lỗi */
    .alert-danger {
        margin-top: 20px;
        font-size: 13px;
        background: #fbe9e7;
        padding: 12px;
        border-radius: 8px;
        color: #b22222;
        text-align: center;
</style>