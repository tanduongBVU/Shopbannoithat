@{
}

@model Shopbannoithat.Models.Order

<div class="container mt-5">

    <div class="card shadow p-4">

        <h2 class="text-success text-center">
            <i class="fa fa-check-circle"></i> Đặt hàng thành công
        </h2>

        <div class="row">

            <div class="col-md-6">

                <h5>Thông tin đơn hàng</h5>

                <p><b>Mã đơn:</b> #ORD-@Model.Id</p>

                <p>
                    <b>Ngày đặt:</b>
                    @Model.OrderDate.ToString("dd/MM/yyyy HH:mm")
                </p>

                <p><b>Trạng thái:</b> @Model.Status</p>

            </div>

            <div class="col-md-6">

                <h5>Thông tin giao hàng</h5>

                <p><b>Người nhận:</b> @Model.Name</p>

                <p>
                    <b>Địa chỉ:</b>
                    @Model.Address1
                    @if (!string.IsNullOrEmpty(Model.Address2))
                    {
                        <span>, @Model.Address2</span>
                    }
                </p>

                <p><b>Thành phố:</b> @Model.City</p>

                @if (!string.IsNullOrEmpty(Model.Zip))
                {
                    <p><b>Zip:</b> @Model.Zip</p>
                }

            </div>

        </div>

        <hr />

        <h5>Sản phẩm đã đặt</h5>

        <table class="table table-bordered">

            <thead class="table-light">

                <tr>
                    <th>Sản phẩm</th>
                    <th>Giá</th>
                    <th>Số lượng</th>
                    <th>Tổng</th>
                </tr>

            </thead>

            <tbody>

                @foreach (var item in Model.OrderDetails)
                {
                    <tr>

                        <td>@item.Product.Name</td>

                        <td>
                            @item.Price.ToString("N0") VNĐ
                        </td>

                        <td>
                            @item.Quantity
                        </td>

                        <td>
                            @((item.Price * item.Quantity).ToString("N0")) VNĐ
                        </td>

                    </tr>
                }

            </tbody>

        </table>

        <div class="text-end mt-3">

            <h4 class="text-danger">
                Tổng tiền: @Model.TotalPrice.ToString("N0") VNĐ
            </h4>

        </div>

        <div class="text-center mt-4">

            <a asp-controller="Product"
                   asp-action="Index"
                   class="btn btn-primary">
                Tiếp tục mua sắm
            </a>

        </div>

    </div>

</div>