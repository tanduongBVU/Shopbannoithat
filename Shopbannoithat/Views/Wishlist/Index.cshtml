@{
}

@model List<Shopbannoithat.Models.WishlistItem>

<h2>Wishlist</h2>

<div class="row">

    @foreach (var item in Model)
    {
        <div class="col-md-3 mb-4">

            <div class="card h-100 shadow-sm">

                <img src="~/images/@item.Image" class="card-img-top" />

                <div class="card-body text-center">

                    <h5 class="card-title">@item.Name</h5>

                    <p class="text-danger fw-bold">
                        @item.Price.ToString("N0") VNĐ
                    </p>

                    
                    <!-- Button xem chi tiết -->
                    <a asp-controller="Product" asp-action="Details" asp-route-id="@item.ProductId" class="btn btn-primary btn-sm">
                        Xem chi tiết
                    </a>

                    <a asp-controller="Wishlist" asp-action="Remove"
                       asp-route-id="@item.ProductId"
                       class="btn btn-danger btn-sm">
                        🗑
                    </a>

                </div>

            </div>

        </div>
    }

</div>