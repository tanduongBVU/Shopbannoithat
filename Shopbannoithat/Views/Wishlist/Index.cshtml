<div class="row">
    @foreach (var item in Model)
    {
        <div class="col-md-4 col-lg-3 mb-4">

            <div class="card h-100 shadow-sm wishlist-card">

                <div class="img-wrapper">
                    <img src="~/images/@item.Image" class="card-img-top wishlist-img" alt="@item.Name" />
                </div>

                <div class="card-body d-flex flex-column text-center">

                    <h5 class="card-title wishlist-title">@item.Name</h5>

                    <p class="wishlist-price fw-bold mb-3">
                        @item.Price.ToString("N0") VNĐ
                    </p>

                    <div class="mt-auto d-flex justify-content-center gap-2">
                        <a asp-controller="Product" asp-action="Details" asp-route-id="@item.ProductId" class="btn btn-detail btn-sm px-3">
                            Xem chi tiết
                        </a>

                        <a asp-controller="Wishlist" asp-action="Remove" asp-route-id="@item.ProductId" class="btn btn-remove btn-sm" title="Xóa khỏi wishlist">
                            <i class="bi bi-trash"></i>
                        </a>
                    </div>

                </div>
            </div>
        </div>
    }
</div>
<style>
    /* --- CÁC STYLE CHO WISHLIST --- */

    /* Thẻ sản phẩm */
    .wishlist-card {
        border: 1px solid #f0f0f0;
        border-radius: 12px;
        transition: all 0.3s ease;
        overflow: hidden; /* Để phần ảnh không bị lòi ra khỏi góc bo tròn */
    }

        /* Hiệu ứng khi di chuột vào Thẻ */
        .wishlist-card:hover {
            transform: translateY(-5px); /* Nâng nhẹ card lên */
            box-shadow: 0 12px 24px rgba(0, 0, 0, 0.1) !important;
            border-color: #e2e2e2;
        }

    /* Bọc ảnh để làm hiệu ứng zoom */
    .img-wrapper {
        overflow: hidden;
    }

    /* Ảnh sản phẩm */
    .wishlist-img {
        height: 260px; /* Chiều cao cố định để các card bằng nhau */
        object-fit: cover; /* Cắt ảnh cho vừa khung mà không bị méo tỉ lệ */
        transition: transform 0.5s ease;
    }

    .wishlist-card:hover .wishlist-img {
        transform: scale(1.05); /* Zoom ảnh nhẹ khi hover */
    }

    /* Tiêu đề sản phẩm */
    .wishlist-title {
        font-size: 1.1rem;
        color: #333;
        margin-bottom: 0.5rem;
        /* Rút gọn text hiển thị dấu ... nếu tên quá dài (tối đa 2 dòng) */
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        height: 3rem; /* Đảm bảo chiều cao khung tên không bị xô lệch */
    }

    /* Giá sản phẩm */
    .wishlist-price {
        color: #dc3545; /* Màu đỏ tiêu chuẩn, có thể đổi theo tông màu của shop */
        font-size: 1.15rem;
    }

    /* --- TÙY CHỈNH NÚT BẤM --- */

    /* Nút Xem chi tiết */
    .btn-detail {
        background-color: #2a1f14;
        color: white;
        border: none;
        border-radius: 6px;
        font-weight: 500;
        transition: background-color 0.2s;
    }

        .btn-detail:hover {
            background-color: #e06a1d;
            color: white;
        }

    /* Nút Xóa (Thùng rác) */
    .btn-remove {
        background-color: #f8d7da; /* Nền đỏ nhạt */
        color: #dc3545; /* Chữ/Icon đỏ đậm */
        border: none;
        border-radius: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 32px; /* Cho nút thành hình vuông cân đối */
        transition: all 0.2s;
    }

        .btn-remove:hover {
            background-color: #dc3545;
            color: white; /* Đổi màu khi hover */
        }
</style>