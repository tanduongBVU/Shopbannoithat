                    <li><a href="/Product/ByCategory/phong-khach">Phòng khách</a></li>
                    <li><a href="/Product/ByCategory/phong-ngu">Phòng ngủ</a></li>
                    <li><a href="/Product/ByCategory/phong-bep">Phòng bếp</a></li>
