<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Shopbannoithat</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Shopbannoithat.styles.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark custom-navbar">
        <div class="container">

            <!-- Logo -->
            <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                ShopNoiThat
            </a>

            <!-- Button mobile -->
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainMenu">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainMenu">

                <!-- Menu trái -->
                <ul class="navbar-nav me-auto">

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">
                            Trang chủ
                        </a>
                    </li>

                    <!-- Dropdown sản phẩm -->
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                            Sản phẩm
                        </a>

                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="#">Sofa</a></li>
                            <li><a class="dropdown-item" href="#">Bàn</a></li>
                            <li><a class="dropdown-item" href="#">Ghế</a></li>
                            <li><a class="dropdown-item" href="#">Tủ</a></li>
                            <li><a class="dropdown-item" href="#">Giường</a></li>
                        </ul>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Product" asp-action="Index">
                            Tất cả sản phẩm
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Wishlist" asp-action="Index">
                            Wishlist
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Cart" asp-action="Index">
                            Giỏ hàng
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Order" asp-action="Index">
                            Đơn hàng
                        </a>
                    </li>

                </ul>

                <!-- Menu phải -->
                <ul class="navbar-nav">

                    <li class="nav-item">
                        <a class="nav-link" asp-area="Identity" asp-page="/Account/Login">
                            Đăng nhập
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="btn btn-login ms-2" asp-area="Identity" asp-page="/Account/Register">
                            Đăng ký
                        </a>
                    </li>

                </ul>

            </div>
        </div>
    </nav>
    <div class="container-fluid p-0">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - Shopbannoithat - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
