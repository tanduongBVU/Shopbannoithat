

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ShopNoiThat</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <!-- Icon -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

</head>

<body>

    <nav class="navbar navbar-expand-lg navbar-dark custom-navbar fixed-top">
        <div class="container">

            <!-- Logo -->
            <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                🪑 ShopNoiThat
            </a>

            <button class="navbar-toggler" type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#mainMenu">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainMenu">

                <!-- Menu trái -->
                <ul class="navbar-nav me-auto">

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-house"></i> Trang chủ
                        </a>
                    </li>

                <li class="nav-item mega-menu-wrap" id="megaMenuTrigger">
                        <a class="nav-link" href="/Product">
                            <i class="bi bi-grid"></i> Sản phẩm
                            <i class="bi bi-chevron-down" style="font-size:11px;"></i>
                        </a>

                        <!-- Mega Menu -->
                        <div class="mega-menu" id="megaMenu">
                            <div class="mega-menu-inner">

                                <!-- Cột trái: danh sách phòng -->
                                <div class="mega-col-rooms">
                                    <a href="/Product" class="mega-room-item">
                                        <i class="bi bi-grid-fill me-2"></i> Tất cả sản phẩm
                                    </a>
                                    <a href="/Product/ByCategory/phong-khach"
                                       class="mega-room-item" data-slug="phong-khach"
                                       onmouseenter="showSub('phong-khach')">
                                        Phòng khách <i class="bi bi-chevron-right ms-auto"></i>
                                    </a>
                                    <a href="/Product/ByCategory/phong-ngu"
                                       class="mega-room-item" data-slug="phong-ngu"
                                       onmouseenter="showSub('phong-ngu')">
                                        Phòng ngủ <i class="bi bi-chevron-right ms-auto"></i>
                                    </a>
                                    <a href="/Product/ByCategory/phong-bep"
                                       class="mega-room-item" data-slug="phong-bep"
                                       onmouseenter="showSub('phong-bep')">
                                        Phòng bếp <i class="bi bi-chevron-right ms-auto"></i>
                                    </a>
                                    <a href="/Product/ByCategory/phong-lam-viec"
                                       class="mega-room-item" data-slug="phong-lam-viec"
                                       onmouseenter="showSub('phong-lam-viec')">
                                        Phòng làm việc <i class="bi bi-chevron-right ms-auto"></i>
                                    </a>
                                </div>

                                <!-- Cột phải: danh mục con -->
                                <div class="mega-col-subs" id="megaSubList">
                                    <div class="mega-sub-placeholder">
                                        <i class="bi bi-arrow-left me-2"></i>
                                        Rê chuột vào phòng để xem loại sản phẩm
                                    </div>
                                </div>

                            </div>
                        </div>
                </li>

                  
                    <li class="nav-item position-relative">
                        <a class="nav-link" asp-controller="Wishlist" asp-action="Index">
                            <i class="bi bi-heart"></i> Wishlist
                            <span id="wishlist-count"
                                  class="badge bg-danger rounded-pill">0</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Cart" asp-action="Index">
                            <i class="bi bi-cart"></i> Giỏ hàng
                            <span class="badge bg-danger rounded-pill" id="cart-count">0</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Order" asp-action="Index">
                            <i class="bi bi-bag"></i> Đơn hàng
                        </a>
                    </li>

                </ul>

                <!-- Search -->
                <form class="d-flex me-3 position-relative"
                      asp-controller="Product"
                      asp-action="Search">

                    <input class="form-control me-2"
                           id="searchBox"
                           type="search"
                           name="keyword"
                           autocomplete="off"
                           placeholder="Tìm sản phẩm...">

                    <button class="btn btn-light">
                        <i class="bi bi-search"></i>
                    </button>

                    <div id="searchResult" class="search-dropdown"></div>

                </form>

                <!-- Menu phải -->
                @{
                    var email = Context.Session.GetString("UserEmail");
                    var role = Context.Session.GetString("UserRole");
                    var name = Context.Session.GetString("UserName");
                }

                <ul class="navbar-nav">

                    @if (email != null)
                    {
                        @* Nếu là Admin *@
                        if (role == "Admin")
                        {
                            <li class="nav-item">
                                <a class="nav-link text-warning"
                                   asp-area="Admin"
                                   asp-controller="Dashboard"
                                   asp-action="Index">
                                    <i class="bi bi-speedometer2"></i> Admin
                                </a>
                            </li>
                        }

                        @* STAFF *@
                        if (role == "Staff")
                        {
                            <li class="nav-item">
                                <a class="nav-link text-info"
                                   asp-area="Staff"
                                   asp-controller="Order"
                                   asp-action="Index">
                                    <i class="bi bi-clipboard-check"></i> Staff
                                </a>
                            </li>
                        }

                        @if (role == "Customer")
                        {
                            <li class="nav-item">
                                <span class="nav-link text-light">
                                    <i class="bi bi-person-circle"></i> @name
                                </span>
                            </li>
                        }
                        <li class="nav-item">
                            <a class="nav-link text-danger"
                               asp-controller="Auth"
                               asp-action="Logout">
                                <i class="bi bi-box-arrow-right"></i> Đăng xuất
                            </a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Auth"
                               asp-action="Login">
                                <i class="bi bi-box-arrow-in-right"></i> Đăng nhập
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Auth"
                               asp-action="Register">
                                <i class="bi bi-person-plus"></i> Đăng ký
                            </a>
                        </li>
                    }

                </ul>

            </div>

        </div>

    </nav>
    <br />
    <br />
    <br />
    

    <div class="container mt-3">
        <main role="main">
            @RenderBody()
        </main>
    </div>



