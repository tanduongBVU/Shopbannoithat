<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ShopNoiThat</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <!-- Icon -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
</head>

<body>

    <nav class="navbar navbar-expand-lg navbar-dark custom-navbar">
        <div class="container">

            <!-- Logo -->
            <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                🪑 ShopNoiThat
            </a>

            <button class="navbar-toggler" type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#mainMenu">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainMenu">

                <!-- Menu trái -->
                <ul class="navbar-nav me-auto">

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-house"></i> Trang chủ
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Product" asp-action="Index">
                            <i class="bi bi-grid"></i> Sản phẩm
                        </a>
                    </li>

                   @*  <li class="nav-item">
                        <a class="nav-link" asp-controller="Wishlist" asp-action="Index">
                            <i class="bi bi-heart"></i> Wishlist
                            (<span id="wishlist-count">0</span>)
                        </a>
                    </li> *@
                    <li class="nav-item position-relative">

                        <a class="nav-link" asp-controller="Wishlist" asp-action="Index">
                            <i class="bi bi-heart"></i> Wishlist
                        </a>

                        <span id="wishlist-count"
                              class="badge bg-danger position-absolute top-0 start-100 translate-middle rounded-pill">
                            0
                        </span>

                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Cart" asp-action="Index">
                            <i class="bi bi-cart"></i> Giỏ hàng
                            <span class="badge bg-danger" id="cart-count">0</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Order" asp-action="Index">
                            <i class="bi bi-bag"></i> Đơn hàng
                        </a>
                    </li>

                </ul>

                <!-- Search -->
                <form class="d-flex me-3" asp-controller="Product" asp-action="Search">
                    <input class="form-control me-2"
                           type="search"
                           name="keyword"
                           placeholder="Tìm sản phẩm...">
                    <button class="btn btn-light">
                        <i class="bi bi-search"></i>
                    </button>
                </form>

                <!-- Menu phải -->
                @{
                    var email = Context.Session.GetString("UserEmail");
                    var role = Context.Session.GetString("UserRole");
                }

                <ul class="navbar-nav">

                    @if (email != null)
                    {
                        @* Nếu là Admin *@
                        if (role == "Admin")
                        {
                            <li class="nav-item">
                                <a class="nav-link text-warning"
                                   asp-area="Admin"
                                   asp-controller="Dashboard"
                                   asp-action="Index">
                                    <i class="bi bi-speedometer2"></i> Admin
                                </a>
                            </li>
                        }

                        @* STAFF *@
                        if (role == "Staff")
                        {
                            <li class="nav-item">
                                <a class="nav-link text-info"
                                   asp-area="Staff"
                                   asp-controller="Order"
                                   asp-action="Index">
                                    <i class="bi bi-clipboard-check"></i> Staff
                                </a>
                            </li>
                        }

                        <li class="nav-item">
                            <a class="nav-link text-danger"
                               asp-controller="Auth"
                               asp-action="Logout">
                                <i class="bi bi-box-arrow-right"></i> Đăng xuất
                            </a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Auth"
                               asp-action="Login">
                                <i class="bi bi-box-arrow-in-right"></i> Đăng nhập
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Auth"
                               asp-action="Register">
                                <i class="bi bi-person-plus"></i> Đăng ký
                            </a>
                        </li>
                    }

                </ul>

            </div>
        </div>
    </nav>

    <div class="container mt-3">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-4">
        <div class="container text-center">
            © 2026 - ShopNoiThat
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <script>

        function loadCartCount(){

        $.get("/Cart/GetCartCount", function(data){

        $("#cart-count").text(data);

        });

        }

        loadCartCount();

    </script>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <script>

        $(document).ready(function () {

            $.get("/Wishlist/Count", function (data) {
                $("#wishlist-count").text(data);
            });

        });

    </script>
</body>
</html>