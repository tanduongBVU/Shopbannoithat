@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}

@model List<Shopbannoithat.Models.Cart>

<h2>Giỏ hàng</h2>

<table class="table">

    <thead>
        <tr>
            <th>Ảnh</th>
            <th>Tên</th>
            <th>Giá</th>
            <th>Số lượng</th>
            <th>Thành tiền</th>
            <th>Thao tác</th>  @* ← thêm cái này *@
            <th>Điều chỉnh</th>  @* ← thêm cái này *@
            <th></th>
        </tr>
    </thead>

    <tbody>

        @{
            decimal total = 0;
        }

        @foreach (var item in Model)
        {
            var variant = item.Product.Variants.FirstOrDefault(v =>
            v.SizeId == item.SizeId &&
            v.MaterialId == item.MaterialId &&
            v.ColorId == item.ColorId
            );

            var price = variant?.Price ?? item.Product.Price ?? 0;
            var thanhTien = price * item.Quantity;
            total += thanhTien;

            <tr>

                <td>
                    <img src="~/images/@item.Product.Image" width="80" />
                </td>

                <td>
                    @item.Product.Name <br />
                    <small style="color:#777;">
                        Size: @variant?.Size?.Name |
                        Material: @variant?.Material?.Name |
                        Color: @variant?.Color?.Name
                    </small>
                </td>

                <td>
                    @price.ToString("N0") VNĐ
                </td>

                <td>
                    @item.Quantity
                </td>

                <td>
                    @thanhTien.ToString("N0") VNĐ
                </td>

                <td>
                    <a asp-controller="Cart" asp-action="Remove"
                       asp-route-id="@item.ProductId"
                       asp-route-sizeId="@item.SizeId"
                       asp-route-materialId="@item.MaterialId"
                       asp-route-colorId="@item.ColorId"
                           class="btn btn-danger">
                        Xóa
                    </a>
                </td>

                <td>

                    <a asp-controller="Cart" asp-action="Decrease"
                       asp-route-id="@item.ProductId"
                       asp-route-sizeId="@item.SizeId"
                       asp-route-materialId="@item.MaterialId"
                       asp-route-colorId="@item.ColorId"
                       class="btn btn-sm btn-secondary">-</a>

                    @item.Quantity

                    <a asp-controller="Cart" asp-action="Increase"
                       asp-route-id="@item.ProductId"
                       asp-route-sizeId="@item.SizeId"
                       asp-route-materialId="@item.MaterialId"
                       asp-route-colorId="@item.ColorId"
                       class="btn btn-sm btn-secondary">+</a>

                </td>

            </tr>
        }

    </tbody>

</table>

<h4>Tổng tiền: <span class="text-danger">@total.ToString("N0") VNĐ</span></h4>

<br />

<a asp-controller="Product"
       asp-action="Index"
       class="btn btn-secondary">
    Tiếp tục mua sắm
</a>

<a asp-controller="Order"
       asp-action="Checkout"
       class="btn btn-success">
    Thanh toán
</a>
<style>
    /* Tổng thể bảng giỏ hàng */
    .table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 20px;
        background-color: #fdfdfd;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        border-radius: 8px;
        overflow: hidden;
    }

        /* Header bảng */
        .table thead {
            background-color: #6b4f3b; /* màu nâu gỗ */
            color: #fff;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-weight: 600;
        }

        .table th, .table td {
            padding: 12px 16px;
            text-align: center;
            border-bottom: 1px solid #ddd;
        }

        /* Hình ảnh sản phẩm */
        .table img {
            border-radius: 6px;
            box-shadow: 0 1px 4px rgba(0,0,0,0.2);
        }

    /* Nút hành động */
    .btn {
        border-radius: 4px;
        font-size: 14px;
        padding: 6px 12px;
        transition: all 0.3s ease;
    }

    .btn-danger {
        background-color: #b23b3b;
        border: none;
    }

        .btn-danger:hover {
            background-color: #922d2d;
        }

    .btn-secondary {
        background-color: #6b4f3b;
        border: none;
        color: #fff;
    }

        .btn-secondary:hover {
            background-color: #4a3223;
        }

    .btn-success {
        background-color: #c44e22;
        border: none;
    }

        .btn-success:hover {
            background-color: #1d5c2d;
        }

    /* Tổng tiền */
    h4 {
        font-weight: 600;
        margin-top: 20px;
    }

        h4 .text-danger {
            font-size: 20px;
            color: #b23b3b;
        }

    /* Nút tiếp tục mua sắm và thanh toán */
    a.btn {
        margin-right: 10px;
        text-decoration: none;
    }

    .table tbody tr:hover {
        background-color: #f5f0eb; /* màu be nhẹ */
    }

</style>